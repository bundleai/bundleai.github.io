---
interface Props {
  title: string;
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  note?: string;
}

const {
  title,
  sub,
  primaryLabel = 'Join the waitlist',
  primaryHref = '/waitlist',
  secondaryLabel,
  secondaryHref,
  note = 'Capital at risk. Bundle is education-first and pre-launch — joining the waitlist commits you to nothing.',
} = Astro.props;
---

<section class="section tight">
  <div class="container">
    <div class="cta-band reveal">
      <div class="cta-inner">
        <h2 class="h2" set:html={title} />
        {sub && <p class="cta-sub" set:html={sub} />}
        <div class="cta-actions">
          <a href={primaryHref} class="btn btn-primary btn-lg">
            {primaryLabel}
            <span class="arrow">→</span>
          </a>
          {
            secondaryLabel && secondaryHref && (
              <a href={secondaryHref} class="btn btn-ghost-light btn-lg btn">
                {secondaryLabel}
              </a>
            )
          }
        </div>
        {note && <p class="cta-note">{note}</p>}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    background: var(--ink);
    border-radius: var(--r-l);
    overflow: hidden;
    box-shadow: var(--shadow-l);
  }

  .cta-band::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.09) 1px, transparent 1.6px);
    background-size: 24px 24px;
    -webkit-mask-image: radial-gradient(80% 100% at 50% 0%, #000 20%, transparent 80%);
    mask-image: radial-gradient(80% 100% at 50% 0%, #000 20%, transparent 80%);
  }

  .cta-band::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 70% at 85% 20%, rgba(13, 126, 138, 0.35), transparent 70%);
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    padding: clamp(2.75rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
  }

  .cta-inner h2 {
    color: #fff;
  }

  .cta-inner h2 :global(.serif-aside),
  .cta-inner h2 :global(em) {
    color: #9fd4dc;
  }

  .cta-sub {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.08rem;
    max-width: 38rem;
    margin-inline: auto;
  }

  .cta-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.9rem;
  }

  .btn-ghost-light {
    border-color: rgba(255, 255, 255, 0.32);
    color: #fff;
    background: transparent;
  }

  .btn-ghost-light:hover {
    border-color: #fff;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .cta-note {
    margin: 1.5rem auto 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 34rem;
  }
</style>
