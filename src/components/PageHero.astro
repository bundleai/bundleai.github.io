---
/**
 * Interior page hero. Slot = optional visual (right side) or full-width content below.
 */
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  center?: boolean;
}

const { eyebrow, title, lead, center = false } = Astro.props;
const hasVisual = Astro.slots.has('visual');
---

<section class:list={['page-hero bg-grid', { center, 'has-visual': hasVisual }]}>
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">{eyebrow}</p>
        <h1 class="display reveal" style="--d:.06s" set:html={title} />
        {lead && <p class="lead reveal" style="--d:.12s" set:html={lead} />}
        <div class="hero-actions reveal" style="--d:.18s">
          <slot name="actions" />
        </div>
      </div>
      {
        hasVisual && (
          <div class="hero-visual reveal" style="--d:.2s">
            <slot name="visual" />
          </div>
        )
      }
    </div>
    <slot />
  </div>
</section>

<style>
  .page-hero {
    padding-block: clamp(3.5rem, 8vw, 6.5rem) clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(60% 60% at 82% 0%, rgba(13, 126, 138, 0.06), transparent 65%),
      var(--bg);
  }

  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .has-visual .hero-grid {
    grid-template-columns: 1.05fr 0.95fr;
  }

  .page-hero.center .hero-copy {
    text-align: center;
    max-width: 50rem;
    margin-inline: auto;
  }

  .page-hero.center .eyebrow::before {
    display: none;
  }

  .hero-copy .lead {
    margin-top: 0.4rem;
  }

  .page-hero.center .lead {
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .hero-actions:empty {
    display: none;
  }

  .page-hero.center .hero-actions {
    justify-content: center;
  }

  @media (max-width: 920px) {
    .has-visual .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
