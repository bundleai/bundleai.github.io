---
/**
 * Interior page hero. Slot = optional visual (right side) or full-width content below.
 */
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  center?: boolean;
}

const { eyebrow, title, lead, center = false } = Astro.props;
const hasVisual = Astro.slots.has('visual');
---

<section class:list={['page-hero bg-grid aurora grain', { center, 'has-visual': hasVisual }]}>
  <svg class="hero-rings" viewBox="0 0 640 640" aria-hidden="true">
    <circle cx="320" cy="320" r="150" fill="none" stroke="var(--teal)" stroke-opacity="0.1" stroke-width="1.5"></circle>
    <circle cx="320" cy="320" r="220" fill="none" stroke="var(--teal)" stroke-opacity="0.08" stroke-width="1.5"></circle>
    <circle cx="320" cy="320" r="290" fill="none" stroke="var(--sage)" stroke-opacity="0.1" stroke-width="1.5" stroke-dasharray="3 14" stroke-linecap="round" class="ring-spin"></circle>
  </svg>
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">{eyebrow}</p>
        <h1 class="display reveal" style="--d:.06s" set:html={title} />
        {lead && <p class="lead reveal" style="--d:.12s" set:html={lead} />}
        <div class="hero-actions reveal" style="--d:.18s">
          <slot name="actions" />
        </div>
      </div>
      {
        hasVisual && (
          <div class="hero-visual reveal" style="--d:.2s">
            <slot name="visual" />
          </div>
        )
      }
    </div>
    <slot />
  </div>
</section>

<style>
  .page-hero {
    padding-block: clamp(3.5rem, 8vw, 6.5rem) clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(60% 60% at 82% 0%, rgba(13, 126, 138, 0.07), transparent 65%),
      linear-gradient(180deg, #f4f9fa 0%, var(--bg) 55%);
  }

  .hero-rings {
    position: absolute;
    top: -180px;
    right: -190px;
    width: 640px;
    height: 640px;
    z-index: 0;
    pointer-events: none;
  }

  .page-hero.has-visual .hero-rings {
    top: auto;
    bottom: -300px;
    right: -240px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ring-spin {
      transform-box: fill-box;
      transform-origin: center;
      animation: ring-rotate 80s linear infinite;
    }
  }

  @keyframes ring-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 960px) {
    .hero-rings {
      display: none;
    }
  }

  .hero-copy h1 :global(.serif-aside),
  .hero-copy h1 :global(em) {
    background: var(--grad-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: var(--teal-deep);
  }

  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .has-visual .hero-grid {
    grid-template-columns: 1.05fr 0.95fr;
  }

  .page-hero.center .hero-copy {
    text-align: center;
    max-width: 50rem;
    margin-inline: auto;
  }

  .page-hero.center .eyebrow::before {
    display: none;
  }

  .hero-copy .lead {
    margin-top: 0.4rem;
  }

  .page-hero.center .lead {
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .hero-actions:empty {
    display: none;
  }

  .page-hero.center .hero-actions {
    justify-content: center;
  }

  @media (max-width: 920px) {
    .has-visual .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
