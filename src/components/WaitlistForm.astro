---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<form class:list={['waitlist-form', { compact }]} data-waitlist novalidate>
  <div class="wf-fields">
    {
      !compact && (
        <div class="wf-segment" role="radiogroup" aria-label="I am joining as">
          <label class="seg-opt">
            <input type="radio" name="segment" value="investor" checked />
            <span>I'm an investor</span>
          </label>
          <label class="seg-opt">
            <input type="radio" name="segment" value="founder" />
            <span>I'm a founder</span>
          </label>
        </div>
      )
    }
    <div class="wf-row">
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        aria-label="Email address"
        autocomplete="email"
      />
      <button type="submit" class="btn btn-primary">
        Join the waitlist <span class="arrow">→</span>
      </button>
    </div>
  </div>
  <p class="wf-note">
    No spam, no countdown timers. One considered update a month, and early access
    in order of sign-up.
  </p>
  <div class="wf-success" hidden>
    <span class="tick" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.6 4.6L19 7.5"/></svg>
    </span>
    <div>
      <strong>You're on the list.</strong>
      <p>
        We'll be in touch when early access opens. In the meantime, the
        <a href="/learn">Academy</a> is free — start with
        <a href="/learn/why-diversification-matters">why diversification matters</a>.
      </p>
    </div>
  </div>
</form>

<style>
  .waitlist-form {
    max-width: 34rem;
  }

  .wf-segment {
    display: inline-flex;
    padding: 0.28rem;
    background: var(--tint-soft);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    margin-bottom: 1rem;
  }

  .seg-opt input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .seg-opt span {
    display: inline-block;
    padding: 0.42rem 1.05rem;
    border-radius: var(--r-pill);
    font-size: 0.9rem;
    font-weight: 550;
    color: var(--text-2);
    cursor: pointer;
    transition: all 0.18s ease;
  }

  .seg-opt input:checked + span {
    background: var(--surface);
    color: var(--ink);
    box-shadow: var(--shadow-s);
  }

  .seg-opt input:focus-visible + span {
    outline: 2px solid var(--teal);
    outline-offset: 1px;
  }

  .wf-row {
    display: flex;
    gap: 0.6rem;
  }

  .wf-row input {
    flex: 1;
    min-width: 0;
    padding: 0.78rem 1.1rem;
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    background: var(--surface);
    font: inherit;
    font-size: 0.98rem;
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .wf-row input:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(13, 126, 138, 0.14);
  }

  .wf-note {
    margin: 0.75rem 0 0;
    font-size: 0.82rem;
    color: var(--text-2);
  }

  .wf-success {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    padding: 1.1rem 1.25rem;
    background: var(--sage-tint);
    border: 1px solid rgba(30, 122, 98, 0.22);
    border-radius: var(--r-m);
  }

  .wf-success .tick {
    flex: none;
    width: 22px;
    height: 22px;
    margin-top: 0.15rem;
    border-radius: 50%;
    background: var(--sage-ink);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .wf-success strong {
    color: var(--ink);
  }

  .wf-success p {
    margin: 0.15rem 0 0;
    font-size: 0.92rem;
  }

  @media (max-width: 560px) {
    .wf-row {
      flex-direction: column;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-waitlist]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = form.querySelector<HTMLInputElement>('input[type="email"]');
      if (!email || !email.value || !email.checkValidity()) {
        email?.reportValidity();
        return;
      }
      try {
        const seg =
          form.querySelector<HTMLInputElement>('input[name="segment"]:checked')
            ?.value ?? 'investor';
        const list = JSON.parse(localStorage.getItem('bundle-waitlist') || '[]');
        list.push({ email: email.value, segment: seg, at: new Date().toISOString() });
        localStorage.setItem('bundle-waitlist', JSON.stringify(list));
      } catch {
        /* storage unavailable — success state still shows */
      }
      form.querySelector<HTMLElement>('.wf-fields')?.setAttribute('hidden', '');
      form.querySelector<HTMLElement>('.wf-note')?.setAttribute('hidden', '');
      form.querySelector<HTMLElement>('.wf-success')?.removeAttribute('hidden');
    });
  });
</script>
