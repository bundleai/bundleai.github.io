---
// Brand lockup: mark + wordmark. `tone` switches for dark surfaces.
interface Props {
  size?: number;
  tone?: 'default' | 'white';
  markOnly?: boolean;
}

const { size = 26, tone = 'default', markOnly = false } = Astro.props;
const ink = tone === 'white' ? '#ffffff' : '#0d7e8a';
const alt = tone === 'white' ? 'rgba(255,255,255,.72)' : '#37a98c';
---

<span class:list={['logo', tone]} style={`--logo-size:${size}px`}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 32 32"
    role="img"
    aria-label="Bundle.ai"
  >
    <rect x="2.4" y="15" width="5" height="14" rx="2.5" fill={ink}></rect>
    <rect x="9.8" y="3" width="5" height="26" rx="2.5" fill={ink}></rect>
    <rect x="17.2" y="11" width="5" height="18" rx="2.5" fill={alt}></rect>
    <rect x="24.6" y="7" width="5" height="22" rx="2.5" fill={ink}></rect>
  </svg>
  {!markOnly && <span class="word">Bundle<span class="ai">.ai</span></span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
    text-decoration: none;
  }

  .word {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: calc(var(--logo-size) * 0.82);
    color: var(--ink);
    transform: translateY(-1px);
  }

  .ai {
    color: var(--teal);
    font-weight: 500;
  }

  .logo.white .word {
    color: #fff;
  }

  .logo.white .ai {
    color: rgba(255, 255, 255, 0.72);
  }
</style>
