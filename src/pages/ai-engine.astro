---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import AgentCard from '../components/AgentCard.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const agents = [
  {
    icon: 'search',
    name: 'Market Scanner Agent',
    tagline: 'The crawler that never sleeps',
    does: 'Continuously scans crowdfunding platforms, secondary marketplaces and pre-IPO desks, normalising every listing — price, structure, minimums, deadlines, documents — into one comparable schema.',
    outputs: ['New-listing feed', 'Normalised deal records', 'Deadline tracking'],
  },
  {
    icon: 'pulse',
    name: 'Price Intelligence Agent',
    tagline: 'Every price gets a reference point',
    does: 'Computes implied valuations, premiums and discounts against the company’s last primary round, and flags when the same name is priced differently across venues.',
    outputs: ['Premium/discount vs last round', 'Cross-venue price gaps', 'Valuation history'],
  },
  {
    icon: 'doc-check',
    name: 'Deal Summariser Agent',
    tagline: 'Reads the documents so you start informed',
    does: 'Digests campaign pages, tender terms and disclosure packs into a plain-English summary: what you’d own, what rights attach, what fees apply, what the seller says and doesn’t say.',
    outputs: ['Plain-English summary', 'Fee breakdown', 'Missing-disclosure list'],
  },
  {
    icon: 'gauge',
    name: 'Risk Flag Agent',
    tagline: 'Sceptical by default',
    does: 'Screens every listing for stale disclosure, unverifiable claims, unusual structures, aggressive marketing language and adverse media, and attaches flags a human can inspect.',
    outputs: ['Risk flags', 'Benchmark context', 'Escalation to human review'],
  },
  {
    icon: 'bell',
    name: 'Alert Agent',
    tagline: 'Your screens keep running without you',
    does: 'Watches your saved screens and watchlists across all venues, and fires alerts on new listings, price moves, funding milestones and closing deadlines — minutes after they happen.',
    outputs: ['Listing alerts', 'Price-move alerts', 'Deadline warnings'],
  },
  {
    icon: 'pie',
    name: 'Portfolio Sync Agent',
    tagline: 'One P&L out of many venues',
    does: 'Turns confirmations and statements from each venue into a single portfolio view, revaluing positions as new rounds price and tracking liquidity events relevant to what you hold.',
    outputs: ['Unified positions', 'Revaluation events', 'Liquidity calendar'],
  },
];

const governance = [
  { icon: 'eye', title: 'Human-in-the-loop', body: 'Agents flag and draft; humans review anything consequential. No agent publishes a risk flag or delists a venue alone.' },
  { icon: 'doc', title: 'Explainable outputs', body: 'Every summary and flag arrives with its reasoning and its sources. If we can’t explain it, we don’t ship it.' },
  { icon: 'lock', title: 'Every output logged', body: 'AI-assisted assessments are recorded and auditable — by us, and by regulators when asked.' },
  { icon: 'scale', title: 'No advice, ever', body: 'The engine describes the market. It never scores “buy”, never ranks by what pays us, and never tells you what to do.' },
];

const faqs = [
  {
    q: 'Does the AI tell me what to invest in?',
    a: 'No. It finds, normalises, summarises and flags. The engine will tell you a block is priced 8% below the last round; it will never tell you that makes it a buy. What you do with the information is yours.',
  },
  {
    q: 'How fresh is the data?',
    a: 'The scanner runs continuously and listings carry a last-checked timestamp. Private markets are still private: prices are indicative, disclosure arrives on the venue’s schedule, and Bundle shows you exactly how stale anything is rather than pretending otherwise.',
  },
  {
    q: 'What happens when the AI gets something wrong?',
    a: 'Summaries link to their sources, so you can check the original documents in one click. Flags are reviewed by humans before they affect how a deal is displayed. And every output is logged, so errors can be traced and corrected, not shrugged off.',
  },
];
---

<BaseLayout
  title="The Bundle AI Engine"
  description="Six agents that scan, normalise, price, summarise and monitor the whole private market — with human oversight, explainable outputs and no investment advice."
>
  <PageHero
    eyebrow="The AI Engine"
    title="Agents watch the market <em>so you can trade it.</em>"
    lead="Aggregating a fragmented market is a reading problem at industrial scale — thousands of listings, documents and price points across venues. That's what the engine does all day. Zero of it is investment advice."
  >
    <a slot="actions" href="/deals" class="btn btn-primary btn-lg">See the output <span class="arrow">→</span></a>
    <a slot="actions" href="/trust" class="btn btn-ghost btn-lg">Governance & safety</a>
  </PageHero>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The agents</p>
        <h2 class="h2 reveal" style="--d:.05s">Six agents, one tape</h2>
      </div>
      <div class="grid cols-2 agents-grid">
        {agents.map((a) => <AgentCard {...a} />)}
      </div>
    </div>
  </section>

  <section class="section section-ink grain">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Governance</p>
        <h2 class="h2 reveal" style="--d:.05s">Powerful engine, short leash</h2>
      </div>
      <div class="grid cols-4">
        {
          governance.map((g, i) => (
            <article class="gov-card reveal" style={`--d:${i * 0.06}s`}>
              <span class="icon-chip"><Icon name={g.icon} size={19} /></span>
              <h3 class="gov-title">{g.title}</h3>
              <p class="small" style="margin:0;color:#a9bcc7">{g.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow reveal">Straight answers</p>
        <h2 class="h2 reveal" style="--d:.05s">The questions worth asking any AI product</h2>
      </div>
      <FAQ items={faqs} class="reveal" />
    </div>
  </section>

  <CTABand
    title="Let the agents do <em>the reading.</em>"
    sub="Screener, summaries and alerts — free for investors in early access."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse live deals"
    secondaryHref="/deals"
  />
</BaseLayout>

<style>
  .agents-grid {
    gap: 1.25rem;
  }

  .gov-card {
    display: grid;
    gap: 0.7rem;
    align-content: start;
    padding: 1.4rem;
    border: 1px solid var(--line-2);
    border-radius: var(--r-m);
    background: rgba(255, 255, 255, 0.015);
  }

  .gov-title {
    margin: 0;
    color: #fff;
    font-size: 1.02rem;
  }
</style>
