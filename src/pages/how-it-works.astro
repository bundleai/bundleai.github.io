---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';

const steps = [
  {
    num: '01',
    icon: 'search',
    title: 'Scan',
    body: 'Bundle continuously scans the venues where private-market deals actually live — crowdfunding platforms, secondary marketplaces, pre-IPO desks. New listings hit your screen the moment they hit the market.',
  },
  {
    num: '02',
    icon: 'sliders',
    title: 'Screen',
    body: 'Cut the whole market by sector, valuation, minimum ticket, venue or market type. Save the screen, and Bundle keeps watching it after you close the tab.',
  },
  {
    num: '03',
    icon: 'scale',
    title: 'Compare',
    body: 'The same company often trades in more than one place at more than one price. Bundle lines up price, fees, minimums, share class and access requirements — so you route the order to the best venue.',
  },
  {
    num: '04',
    icon: 'exchange',
    title: 'Execute',
    body: 'One click drops you into the live deal on the venue that lists it. You invest under that venue’s regulatory protections; Bundle never touches your money.',
  },
  {
    num: '05',
    icon: 'pie',
    title: 'Track',
    body: 'Positions across every venue sync into one portfolio — one P&L, revaluations as new rounds price, and alerts when liquidity opens up for something you hold.',
  },
];

const isnt = [
  { is: true, text: 'A screener for the entire private market — crowdfunding, secondaries, pre-IPO' },
  { is: true, text: 'A comparison layer: price, fees, minimums and access, venue by venue' },
  { is: true, text: 'A single portfolio and alert engine across every venue you use' },
  { is: false, text: 'A broker or exchange — trades execute on the venue that lists the deal' },
  { is: false, text: 'A custodian — Bundle never holds your money or your shares' },
  { is: false, text: 'An adviser — we show the whole market, we don’t tell you what to buy' },
];
---

<BaseLayout
  title="How it works"
  description="How Bundle works: scan every private-market venue, screen and compare deals, execute on the listing venue, and track it all in one portfolio."
>
  <PageHero
    eyebrow="How it works"
    title="From scattered venues to <em>one order flow.</em>"
    lead="The deals were always out there — spread across a dozen tabs, logins and mailing lists. Bundle collapses them into a single screen and gets you from discovery to execution in minutes."
  >
    <a slot="actions" href="/deals" class="btn btn-primary btn-lg">Open the screener <span class="arrow">→</span></a>
    <a slot="actions" href="/waitlist" class="btn btn-ghost btn-lg">Get early access</a>
  </PageHero>

  <!-- Steps -->
  <section class="section">
    <div class="container">
      <ol class="flow">
        {
          steps.map((s, i) => (
            <li class="flow-step reveal" style={`--d:${i * 0.06}s`}>
              <div class="flow-rail">
                <span class="flow-num mono">{s.num}</span>
                <span class="flow-line" />
              </div>
              <div class="flow-card card card-hover">
                <span class="icon-chip"><Icon name={s.icon} /></span>
                <div>
                  <h2 class="h3">{s.title}</h2>
                  <p class="small muted">{s.body}</p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Is / isn't -->
  <section class="section section-ink grain">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow reveal">No small-print surprises</p>
        <h2 class="h2 reveal" style="--d:.05s">What Bundle is — and what it refuses to be</h2>
      </div>
      <ul class="isnt-list reveal" style="--d:.08s">
        {
          isnt.map((row) => (
            <li class:list={['isnt-row', row.is ? 'yes' : 'no']}>
              <span class="isnt-mark">
                <Icon name={row.is ? 'check' : 'close'} size={13} stroke={2.4} />
              </span>
              <span>{row.text}</span>
            </li>
          ))
        }
      </ul>
      <p class="small muted reveal" style="margin-top:1.5rem">
        Every deal carries the risks of the venue that lists it: illiquidity,
        dilution and the real possibility of losing everything you invest.
        <a href="/legal/risk-warning">Read the risk warning</a>.
      </p>
    </div>
  </section>

  <CTABand
    title="See the whole market <em>before everyone else.</em>"
    sub="Early access opens in order of sign-up — screener, watchlists and alerts from day one."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse live deals"
    secondaryHref="/deals"
  />
</BaseLayout>

<style>
  .flow {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 52rem;
    display: grid;
  }

  .flow-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
  }

  .flow-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .flow-num {
    flex: none;
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--line-2);
    background: var(--surface);
    color: var(--teal);
    font-size: 0.8rem;
  }

  .flow-line {
    flex: 1;
    width: 1px;
    background: linear-gradient(180deg, var(--line-2), var(--line));
  }

  .flow-step:last-child .flow-line {
    display: none;
  }

  .flow-card {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    margin-bottom: 1.1rem;
    flex: 1;
  }

  .flow-card h2 {
    margin-bottom: 0.3rem;
  }

  .flow-card .small {
    margin: 0;
    max-width: 52ch;
  }

  .isnt-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .isnt-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.85rem 1.1rem;
    border-radius: var(--r-s);
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.015);
    color: #c3d2dc;
  }

  .isnt-mark {
    flex: none;
    width: 22px;
    height: 22px;
    margin-top: 0.1rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .isnt-row.yes .isnt-mark {
    background: var(--up-tint);
    color: var(--up);
  }

  .isnt-row.no .isnt-mark {
    background: var(--down-tint);
    color: var(--down);
  }
</style>
