---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const freeFeatures = [
  'Full deal screener across every tracked venue',
  'Watchlists on companies, sectors and venues',
  'Price, funding and closing alerts',
  'Cross-venue portfolio tracking, one P&L',
  'Venue comparison: fees, minimums, access',
];

const proFeatures = [
  'Saved screens with instant-fire alerts',
  'Premium/discount analytics vs last round',
  'Deal-doc AI summaries and risk flags',
  'Portfolio exports and tax-season packs',
  'Early access to new venues and markets',
];

const faqs = [
  {
    q: 'Why is the screener free?',
    a: 'Because aggregators win on coverage, and coverage only matters if everyone can see it. The screener, watchlists and portfolio tracking stay free. If we ever charge investors, it will be for extra analytics on top, never for access to the market itself.',
  },
  {
    q: 'So how does Bundle make money?',
    a: 'The Skyscanner model: when a venue runs a referral or partner programme, Bundle may earn a fee when you complete an investment we routed to it. That fee comes from the venue’s marketing budget, not from a markup on your price. Where no programme exists, deals are listed anyway — coverage is ranked by relevance, never by commission.',
  },
  {
    q: 'Do referral fees bias what I see?',
    a: 'The ranking rule is public and simple: search and screener results are ordered by the filters you set, nothing else. Sponsored placements, if we ever run them, will be labelled as such. An aggregator that quietly reorders the market for commission is dead the day users notice; we’d rather not die.',
  },
  {
    q: 'What will Pro cost?',
    a: 'Pro pricing will be published before it launches, and the free tier keeps everything you need to find, compare and track deals. Design goal: a price an active retail investor shrugs at, not a professional-terminal price.',
  },
];
---

<BaseLayout
  title="Pricing"
  description="Bundle is free for investors: the full cross-venue deal screener, watchlists, alerts and portfolio tracking. Revenue comes from venue referrals, never markups."
>
  <PageHero
    center
    eyebrow="Pricing"
    title='The whole market, <em class="serif-aside">free to watch.</em>'
    lead="You don't pay to see the market. Bundle earns venue referral fees when you invest through a routed deal — the price you pay on the venue is never marked up."
  />

  <section class="section">
    <div class="container">
      <div class="grid cols-2 price-grid">
        <article class="card price-card glow-card reveal">
          <div class="pc-head">
            <p class="pc-name">Investor</p>
            <span class="badge badge-up">Free forever</span>
          </div>
          <p class="pc-price">£0</p>
          <p class="pc-sub">Everything you need to scan, compare and track</p>
          <ul class="check-list">
            {
              freeFeatures.map((f) => (
                <li>
                  <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
                  <span>{f}</span>
                </li>
              ))
            }
          </ul>
          <a href="/waitlist" class="btn btn-primary pc-cta">Get early access <span class="arrow">→</span></a>
        </article>

        <article class="card price-card reveal" style="--d:.07s">
          <div class="pc-head">
            <p class="pc-name">Pro</p>
            <span class="badge badge-line">Coming later</span>
          </div>
          <p class="pc-price">TBA</p>
          <p class="pc-sub">Sharper tools for active private-market investors</p>
          <ul class="check-list">
            {
              proFeatures.map((f) => (
                <li>
                  <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
                  <span>{f}</span>
                </li>
              ))
            }
          </ul>
          <a href="/waitlist" class="btn btn-ghost pc-cta">Join the waitlist</a>
        </article>
      </div>

      <div class="panel-tint how-paid reveal">
        <span class="icon-chip"><Icon name="coins" size={19} /></span>
        <div>
          <h2 class="h3">How the money flows</h2>
          <p class="small" style="margin:0">
            You invest on the venue at the venue's price and the venue's fees —
            Bundle adds nothing on top. If that venue runs a partner programme,
            it pays Bundle a referral fee out of its own take. No programme, no
            problem: the deal stays on the tape. Bundle never holds client money,
            never executes trades and never charges a spread.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight section-tint-full">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow reveal">Straight answers</p>
        <h2 class="h2 reveal" style="--d:.05s">Pricing questions, answered plainly</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABand
    title="Free to watch. <em>Fast to act.</em>"
    sub="Early access opens in order of sign-up."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse live deals"
    secondaryHref="/deals"
  />
</BaseLayout>

<style>
  .price-grid {
    max-width: 58rem;
    margin-inline: auto;
  }

  .price-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.9rem;
  }

  .pc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pc-name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--ink);
  }

  .pc-price {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 2.3rem;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .pc-sub {
    margin: -0.4rem 0 0.4rem;
    font-size: 0.9rem;
    color: var(--text-2);
  }

  .pc-cta {
    margin-top: auto;
  }

  .how-paid {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    max-width: 58rem;
    margin: 1.5rem auto 0;
    padding: 1.5rem 1.7rem;
  }

  .how-paid .h3 {
    margin-bottom: 0.35rem;
  }
</style>
