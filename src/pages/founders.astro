---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const benefits = [
  { icon: 'eye', name: 'Demand you didn’t have to buy', desc: 'Your round appears in front of investors screening the whole market — not just the audience of the platform you chose.' },
  { icon: 'doc-check', name: 'A claimed, enriched listing', desc: 'Verify your company, correct the data, add context. A claimed listing outranks a scraped one in completeness, never in commission.' },
  { icon: 'bell', name: 'Watchlist demand signals', desc: 'See how many Bundle investors follow your company or sector — real interest data before and during your raise.' },
  { icon: 'exchange', name: 'Secondary-market visibility', desc: 'Post-raise, employees and early backers can see real venues for liquidity, and investors can see your paper actually trades.' },
];

const tools = [
  { icon: 'doc-check', name: 'Pitch diagnostic', desc: 'Institutional-grade scoring of clarity, traction, model and valuation, with rewrite suggestions.' },
  { icon: 'users', name: 'Investor FAQ generator', desc: 'Anticipates the questions your raise will attract and drafts honest answers for review.' },
  { icon: 'scale', name: 'Valuation benchmark assistant', desc: 'Positions your ask against comparable rounds before an investor does it for you.' },
  { icon: 'route', name: 'Raise-readiness checklist', desc: 'Every disclosure, document and data point investors will look for, tracked in one place.' },
];

const faqs = [
  {
    q: 'Does Bundle host my raise?',
    a: 'No — you raise on the venue you choose (Crowdcube, Republic Europe, Wefunder, or anywhere else we track). Bundle is the aggregation layer that makes sure investors screening the whole market see your round, wherever it lives.',
  },
  {
    q: 'What does claiming my listing cost?',
    a: 'Nothing. Claiming lets you verify the data, add context and see demand signals. Paid placement doesn’t exist today; if it ever does, it will be labelled as sponsored and will never change screener rankings.',
  },
  {
    q: 'Is the Pitch Health Check really free?',
    a: 'Yes. It’s how we meet serious founders early, and it’s genuinely useful even if your raise never touches a venue we track. No obligation, no sales sequence, and your materials aren’t shared anywhere.',
  },
  {
    q: 'My round isn’t showing. Why?',
    a: 'Coverage rolls out venue by venue. If you’re raising on a platform we track and can’t find your round, tell us — missing coverage is a bug, and founder reports are how we catch it fastest.',
  },
];
---

<BaseLayout
  title="For Founders"
  description="Raising on Crowdcube, Republic Europe or Wefunder? Bundle puts your round in front of investors screening the whole private market — and gives you free AI raise tools."
>
  <PageHero
    eyebrow="For founders"
    title='Raise where you like. <em class="serif-aside">Be seen everywhere.</em>'
    lead="Your round lives on one platform, but the investors you want screen the whole market. Bundle aggregates every venue's deal flow — claim your listing so yours shows up sharp."
  >
    <Fragment slot="actions">
      <a href="#health-check" class="btn btn-primary btn-lg">Free AI Pitch Health Check <span class="arrow">→</span></a>
      <a href="/contact" class="btn btn-ghost btn-lg">Claim your listing</a>
    </Fragment>
  </PageHero>

  <!-- Why it matters -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Why founders claim their listing</p>
        <h2 class="h2 reveal" style="--d:.05s">Distribution without another platform to manage</h2>
      </div>
      <div class="grid cols-2">
        {
          benefits.map((b, i) => (
            <article class="card card-hover benefit-card reveal" style={`--d:${(i % 2) * 0.07}s`}>
              <span class="icon-chip"><Icon name={b.icon} /></span>
              <div>
                <h3 class="h3" style="margin-bottom:0.35rem">{b.name}</h3>
                <p class="small muted" style="margin:0">{b.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Health check -->
  <section class="section section-tint-full" id="health-check">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow reveal">The free tool</p>
          <h2 class="h2 reveal" style="--d:.05s">The AI Pitch Health Check</h2>
          <p class="lead reveal" style="--d:.1s">
            Upload a deck; get an institutional-quality read in minutes: a
            scored assessment, the questions investors will ask, the
            disclosures you're missing, and the red flags to fix before anyone
            else sees them.
          </p>
          <div class="hero-actions reveal" style="--d:.15s;display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.5rem">
            <a href="/waitlist" class="btn btn-primary">Get the Health Check <span class="arrow">→</span></a>
          </div>
        </div>
        <div class="grid cols-2 tools-grid reveal" style="--d:.12s">
          {
            tools.map((t) => (
              <article class="card tool-card">
                <span class="icon-chip"><Icon name={t.icon} size={18} /></span>
                <h3 class="tool-name">{t.name}</h3>
                <p class="small muted" style="margin:0">{t.desc}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section tight">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow reveal">Founder questions</p>
        <h2 class="h2 reveal" style="--d:.05s">Asked and answered</h2>
      </div>
      <FAQ items={faqs} class="reveal" />
    </div>
  </section>

  <CTABand
    title="Your raise, on <em>every serious screen.</em>"
    sub="Claim your listing, run the free Health Check, and meet demand from across the market."
    primaryLabel="Claim your listing"
    primaryHref="/contact"
    secondaryLabel="Get early access"
    secondaryHref="/waitlist"
  />
</BaseLayout>

<style>
  .benefit-card {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
  }

  .tools-grid {
    gap: 0.9rem;
  }

  .tool-card {
    padding: 1.2rem;
  }

  .tool-name {
    font-size: 0.98rem;
    margin: 0.8rem 0 0.3rem;
  }
</style>
