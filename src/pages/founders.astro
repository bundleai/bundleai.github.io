---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const tools = [
  { icon: 'doc-check', name: 'Pitch diagnostic', desc: 'Institutional-grade scoring of clarity, traction, model and valuation, with rewrite suggestions.' },
  { icon: 'users', name: 'Investor FAQ generator', desc: 'Anticipates the questions your raise will attract and drafts honest answers for review.' },
  { icon: 'bars', name: 'Financial model review', desc: 'Sanity-checks assumptions, burn, runway and unit economics against stage benchmarks.' },
  { icon: 'route', name: 'Campaign-readiness checklist', desc: 'Every disclosure, document and data point needed before a raise can open, all tracked.' },
  { icon: 'award', name: 'SEIS/EIS documentation tracker', desc: 'Advance assurance, compliance statements, certificates: deadlines and status in one place.' },
  { icon: 'layers', name: 'Cap-table hygiene checker', desc: 'Flags messy structures, missing paperwork and terms that will scare later investors.' },
  { icon: 'scale', name: 'Valuation benchmark assistant', desc: 'Positions your ask against comparable UK rounds before an investor does it for you.' },
];

const raiseSteps = [
  { title: 'Run the Pitch Health Check', body: 'Free, fast, and yours to keep: a scored report on how investment-ready your raise actually is.' },
  { title: 'Get raise-ready with the toolset', body: 'Fix what the diagnostic found: disclosures, model, cap table, SEIS/EIS paperwork. AI-assisted, human-reviewed.' },
  { title: 'Diligence & structured listing', body: 'Our risk and fraud agents plus human review produce the structured risk disclosure investors see. No hype, no burying.' },
  { title: 'Raise from portfolio-aware investors', body: 'Educated investors allocating deliberately across portfolios: fewer tourists, better questions, realistic expectations.' },
];

const faqs = [
  {
    q: 'Why would I raise here instead of Crowdcube or Republic Europe?',
    a: 'Three reasons founders tell us they want: <strong>cost</strong>: lower headline fees, with AI doing the preparation labour incumbents charge for; <strong>fit</strong>: a platform built for technical, B2B and deeptech companies rather than consumer-brand campaigns; and <strong>investor quality</strong>: portfolio-aware, educated investors who understand timelines and dilution, which means less update fatigue and fewer panicked emails later.',
  },
  {
    q: 'What kinds of companies are you looking for?',
    a: 'UK companies raising £100k–£5m at pre-seed, seed or Series A. Our launch focus: AI and automation, B2B SaaS, climate, health, and university spinouts, especially companies with real traction but limited access to the VC club. Consumer businesses with genuine fundamentals are welcome; hype-only campaigns are not.',
  },
  {
    q: 'What does the diligence process involve?',
    a: 'A structured assessment across founder quality, traction, market, revenue quality, financial discipline, valuation reasonableness, competitive advantage, legal/cap-table hygiene, and disclosure quality. AI agents do the heavy reading; humans make the listing decision. The output investors see is a structured risk disclosure. We don’t bless deals as "good investments."',
  },
  {
    q: 'Is the Pitch Health Check really free?',
    a: 'Yes. It’s how we meet serious founders early, and it’s genuinely useful even if you never raise with us. No obligation, no sales sequence, and your materials aren’t shared anywhere.',
  },
  {
    q: 'What about after the raise?',
    a: 'Structured update templates, investor communication tools, dilution and follow-on notifications handled by the platform, so keeping hundreds of small investors informed takes minutes, not days. Better-informed investors plus structured comms is the antidote to crowdfunding’s update-fatigue problem.',
  },
];
---

<BaseLayout
  title="For Founders"
  description="Raise £100k–£5m from informed, portfolio-aware investors, with AI pitch diagnostics, SEIS/EIS tooling and lower fees. Built for technical, B2B, deeptech and spinout founders."
>
  <PageHero
    eyebrow="For founders"
    title='Raise from investors who <em class="serif-aside">understand the asset class</em>'
    lead="Consumer-brand crowdfunding rewards marketing. Bundle is built for the founders it overlooks (technical, B2B, deeptech and university spinouts), with AI-assisted preparation, structured diligence, and investors educated to think in portfolios, not lottery tickets."
  >
    <Fragment slot="actions">
      <a href="#health-check" class="btn btn-primary btn-lg">Free AI Pitch Health Check <span class="arrow">→</span></a>
      <a href="#apply" class="btn btn-ghost btn-lg">Apply to raise</a>
    </Fragment>
  </PageHero>

  <!-- Health check -->
  <section class="section" id="health-check">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow reveal">The free hook, genuinely free</p>
          <h2 class="h2 reveal" style="--d:.05s">The AI Pitch Health Check</h2>
          <p class="lead reveal" style="--d:.1s">
            Upload a deck; get an institutional-quality read in minutes: a scored
            assessment across ten dimensions, the questions investors will ask, the
            disclosures you're missing, and the red flags to fix before anyone else
            sees them.
          </p>
          <ul class="check-list reveal" style="--d:.15s">
            <li><span class="tick"><Icon name="check" size={11} stroke={2.6} /></span><span>Ten-dimension score, from clarity to valuation reasonableness</span></li>
            <li><span class="tick"><Icon name="check" size={11} stroke={2.6} /></span><span>Likely investor questions, drafted before they're asked</span></li>
            <li><span class="tick"><Icon name="check" size={11} stroke={2.6} /></span><span>SEIS/EIS readiness snapshot</span></li>
            <li><span class="tick"><Icon name="check" size={11} stroke={2.6} /></span><span>Private by default: your materials are never shared</span></li>
          </ul>
          <div class="hero-actions-l reveal" style="--d:.2s">
            <a href="/waitlist" class="btn btn-primary">Request early access <span class="arrow">→</span></a>
            <span class="small muted">Health Check opens with the founder beta.</span>
          </div>
        </div>
        <div class="card hc-card reveal" style="--d:.12s" aria-hidden="true">
          <div class="hc-head">
            <span class="icon-chip"><Icon name="doc-check" size={19} /></span>
            <div>
              <span class="hc-title">Pitch Health Check</span>
              <span class="hc-sub mono">caldera-robotics-seed-deck.pdf · 18 slides</span>
            </div>
            <span class="hc-score">
              <span class="hc-num">72</span>
              <span class="hc-denom">/100</span>
            </span>
          </div>
          <div class="hc-rows">
            {
              [
                { k: 'Clarity of proposition', v: 84, c: 'var(--c4)' },
                { k: 'Market sizing', v: 71, c: 'var(--c1)' },
                { k: 'Traction evidence', v: 66, c: 'var(--c1)' },
                { k: 'Financial assumptions', v: 58, c: 'var(--c2)' },
                { k: 'Valuation reasonableness', v: 48, c: 'var(--c2)' },
                { k: 'SEIS/EIS readiness', v: 90, c: 'var(--c4)' },
              ].map((r) => (
                <div class="hc-row">
                  <span>{r.k}</span>
                  <span class="hc-track">
                    <span style={`width:${r.v}%;background:${r.c}`} />
                  </span>
                  <span class="mono hc-val">{r.v}</span>
                </div>
              ))
            }
          </div>
          <div class="hc-flags">
            <p class="hc-flag"><Icon name="alert" size={14} /> Valuation is 2.3× the seed median for UK robotics: justify or expect pushback.</p>
            <p class="hc-flag"><Icon name="alert" size={14} /> No churn data shown for the pilot cohort. Investors will ask.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Toolset -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The founder toolset</p>
        <h2 class="h2 reveal" style="--d:.05s">Seven tools that replace an expensive month</h2>
        <p class="lead reveal" style="--d:.1s">
          The preparation work advisers bill for: automated where AI is good at it,
          reviewed by humans where it isn't.
        </p>
      </div>
      <div class="grid cols-4 tools-grid">
        {
          tools.map((t, i) => (
            <article class="card card-hover reveal" style={`--d:${(i % 4) * 0.06}s`}>
              <span class="icon-chip"><Icon name={t.icon} size={19} /></span>
              <h3 class="tool-name">{t.name}</h3>
              <p class="small muted" style="margin-bottom:0">{t.desc}</p>
            </article>
          ))
        }
        <article class="card tool-cta reveal" style="--d:.24s">
          <p class="serif-aside tool-cta-line">“The best founders arrive prepared. Now preparation is the default.”</p>
          <a class="text-link" href="#apply">Apply to raise <span class="arrow">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- Who we serve + steps -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">How raising works</p>
        <h2 class="h2 reveal" style="--d:.05s">From first deck to funded, without the circus</h2>
      </div>
      <div class="grid cols-4">
        {
          raiseSteps.map((s, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="step-num">{i + 1}</span>
              <h3 class="h3 card-title">{s.title}</h3>
              <p class="small muted" style="margin-bottom:0">{s.body}</p>
            </article>
          ))
        }
      </div>
      <div class="sourcing-note panel-tint reveal" style="margin-top:2rem">
        <Icon name="building" size={20} />
        <p>
          <strong>Where we source:</strong> accelerators and venture studios,
          university spinout offices (Oxford, Cambridge, Imperial, UCL, Warwick,
          Manchester, Edinburgh), founder communities, and overflow from VC and
          angel networks. If you run one of these and want serious retail-ready
          founders served properly, <a href="/contact">talk to us</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing snapshot -->
  <section class="section section-tint-full" id="apply">
    <div class="container">
      <div class="split wide-left">
        <div>
          <p class="eyebrow reveal">Founder pricing</p>
          <h2 class="h2 reveal" style="--d:.05s">Lower headline fees. Preparation included.</h2>
          <p class="lead reveal" style="--d:.1s">
            Incumbents cluster around 5–7% all-in once fees stack up. Bundle's
            AI-assisted model targets 3–5% success fees with readiness tooling
            included, because software, not headcount, does the per-campaign
            labour.
          </p>
          <div class="hero-actions-l reveal" style="--d:.15s">
            <a href="/pricing" class="btn btn-ghost">Full pricing breakdown</a>
            <a href="/waitlist" class="btn btn-primary">Apply to raise <span class="arrow">→</span></a>
          </div>
        </div>
        <div class="table-wrap reveal" style="--d:.12s">
          <table class="table">
            <tbody>
              <tr><td>Application & readiness</td><td class="num">£250 – £1,000</td></tr>
              <tr><td>Campaign setup</td><td class="num">£1,000 – £3,000</td></tr>
              <tr><td>Success fee</td><td class="num"><strong>3% – 5%</strong> of funds raised</td></tr>
              <tr><td>Payment & admin</td><td class="num">1% – 2%</td></tr>
              <tr><td>Premium pitch support <span class="muted">(optional)</span></td><td class="num">£1,000 – £10,000</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container narrow">
      <div class="section-head center">
        <p class="eyebrow reveal">Questions</p>
        <h2 class="h2 reveal" style="--d:.05s">What founders ask us first</h2>
      </div>
      <FAQ items={faqs} class="reveal" />
    </div>
  </section>

  <CTABand
    title="Serious founders deserve <em class='serif-aside'>serious investors.</em>"
    sub="Run the free Pitch Health Check when the founder beta opens. Join the waitlist and we'll hold your place."
    primaryLabel="Join as a founder"
    secondaryLabel="Talk to the team"
    secondaryHref="/contact"
  />
</BaseLayout>

<style>
  .hero-actions-l {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .hc-card {
    padding: 1.6rem;
  }

  .hc-head {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .hc-title {
    display: block;
    font-weight: 600;
    color: var(--ink);
    font-family: var(--font-display);
  }

  .hc-sub {
    font-size: 0.7rem;
    color: var(--faint);
  }

  .hc-score {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 0.1rem;
  }

  .hc-num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.9rem;
    color: var(--teal-deep);
    letter-spacing: -0.02em;
  }

  .hc-denom {
    font-size: 0.85rem;
    color: var(--faint);
  }

  .hc-rows {
    display: grid;
    gap: 0.65rem;
  }

  .hc-row {
    display: grid;
    grid-template-columns: minmax(10rem, 1fr) 1.1fr 2rem;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.86rem;
    color: var(--text);
  }

  .hc-track {
    height: 9px;
    background: var(--chart-track);
    border-radius: 999px;
    overflow: hidden;
  }

  .hc-track span {
    display: block;
    height: 100%;
    border-radius: 0 4px 4px 0;
  }

  .hc-val {
    text-align: right;
    color: var(--text-2);
    font-size: 0.78rem;
  }

  .hc-flags {
    margin-top: 1.15rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 0.5rem;
  }

  .hc-flag {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    margin: 0;
    font-size: 0.82rem;
    color: var(--sand-ink);
    line-height: 1.5;
  }

  .hc-flag svg {
    flex: none;
    margin-top: 0.2rem;
  }

  .tool-name {
    font-size: 1.02rem;
    margin: 0.95rem 0 0.35rem;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .tool-cta {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--ink);
    border-color: var(--ink);
  }

  .tool-cta-line {
    color: #d7e5e7;
    font-size: 1.12rem;
    line-height: 1.5;
  }

  .tool-cta .text-link {
    color: #9fd4dc;
  }

  .sourcing-note {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.5rem 1.75rem;
  }

  .sourcing-note svg {
    flex: none;
    color: var(--teal-deep);
    margin-top: 0.2rem;
  }

  .sourcing-note p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.65;
  }
</style>
