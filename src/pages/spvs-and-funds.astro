---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';
import DealCard from '../components/DealCard.astro';
import { deals } from '../data/deals';

const preIpo = deals.filter((d) => d.type === 'pre-ipo');

const routes = [
  {
    icon: 'target',
    title: 'Direct blocks',
    body: 'Buy a listed block of shares on a marketplace like Forge or Hiive. Highest minimums, cleanest exposure — you hold the position the venue settles.',
    tag: 'Typical min: $5k–$100k',
  },
  {
    icon: 'layers',
    title: 'SPVs',
    body: 'A special-purpose vehicle pools many investors into one entity that holds the shares. Platforms like Odin and EquityZen run the admin; you hold a slice of the vehicle.',
    tag: 'Typical min: $1k–$10k',
  },
  {
    icon: 'ring',
    title: 'Pre-IPO funds & baskets',
    body: 'Funds hold several late-stage names in one wrapper. Lowest minimums and instant spread — watch fees and any premium to the value of what the fund holds.',
    tag: 'Typical min: $500+',
  },
];

const checks = [
  'The same company, offered as a block, an SPV and a fund — often at different effective prices per share',
  'Management and carry fees, surfaced per route, so cheap headline minimums don’t hide expensive wrappers',
  'Premium or discount to the last primary round, computed the same way across every structure',
  'Access rules per route — accreditation, residency, lockups — before you click through',
];
---

<BaseLayout
  title="Pre-IPO & SPVs"
  description="Compare routes into pre-IPO names — direct secondary blocks, SPVs and pre-IPO funds — across venues, with fees, minimums and premiums side by side."
>
  <PageHero
    eyebrow="Markets · Pre-IPO"
    title="Pre-IPO names, <em>every route priced.</em>"
    lead="SpaceX via a block, an SPV or a fund? The ticket sizes, fees and effective share prices differ wildly. Bundle lines up every route into a name so you can pick the one that fits your cheque."
  >
    <a slot="actions" href="/deals?type=pre-ipo" class="btn btn-primary btn-lg">See pre-IPO deals <span class="arrow">→</span></a>
    <a slot="actions" href="/waitlist" class="btn btn-ghost btn-lg">Get early access</a>
  </PageHero>

  <!-- Live rail -->
  <section class="section tight">
    <div class="container">
      <div class="rail-head reveal">
        <h2 class="h3"><Icon name="bars" size={18} /> Most-watched pre-IPO names</h2>
        <a href="/deals?type=pre-ipo" class="text-link small">Full screener <span class="arrow">→</span></a>
      </div>
      <div class="grid cols-4">
        {preIpo.slice(0, 4).map((d, i) => <DealCard deal={d} class="reveal" style={`--d:${i * 0.06}s`} />)}
      </div>
      <p class="small muted" style="margin-top:0.9rem">
        Illustrative listings — not live quotes or offers.
      </p>
    </div>
  </section>

  <!-- Three routes -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Three routes in</p>
        <h2 class="h2 reveal" style="--d:.05s">Same company, three very different trades</h2>
      </div>
      <div class="grid cols-3">
        {
          routes.map((r, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="icon-chip"><Icon name={r.icon} /></span>
              <h3 class="h3" style="margin-top:1.1rem">{r.title}</h3>
              <p class="small muted">{r.body}</p>
              <span class="badge badge-line mono route-tag">{r.tag}</span>
            </article>
          ))
        }
      </div>
      <p class="small muted reveal" style="margin-top:1rem">
        Ranges are indicative of the market generally, not quotes from any venue.
      </p>
    </div>
  </section>

  <!-- What Bundle compares -->
  <section class="section">
    <div class="container narrow">
      <div class="section-head">
        <p class="eyebrow reveal">What the comparison shows</p>
        <h2 class="h2 reveal" style="--d:.05s">The stuff wrappers usually hide</h2>
      </div>
      <ul class="check-list reveal" style="--d:.08s">
        {
          checks.map((c) => (
            <li>
              <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
              <span>{c}</span>
            </li>
          ))
        }
      </ul>
      <p class="small muted reveal" style="margin-top:1.5rem">
        Pre-IPO investing is still private-market investing: illiquid, high-risk
        and unprotected if things go wrong.
        <a href="/legal/risk-warning">Read the risk warning</a>.
      </p>
    </div>
  </section>

  <CTABand
    title="Pick the route <em>with your eyes open.</em>"
    sub="Every route into every name, priced side by side — from day one of early access."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="See pre-IPO deals"
    secondaryHref="/deals?type=pre-ipo"
  />
</BaseLayout>

<style>
  .rail-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.15rem;
  }

  .rail-head h2 {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
  }

  .rail-head h2 :global(svg) {
    color: var(--teal);
  }

  .route-tag {
    margin-top: 0.4rem;
    font-size: 0.7rem;
  }
</style>
