---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';

const principles = [
  { icon: 'scale', title: 'Neutral ranking, always', body: 'Screener and search results order by the filters you set — price, deadline, sector — never by what a venue pays us. If sponsored placement ever exists, it will be labelled unmistakably.' },
  { icon: 'coins', title: 'No markups, no spreads', body: 'You pay the venue’s price and the venue’s fees. Bundle’s referral revenue comes out of the venue’s take, and a deal with no referral programme is displayed identically to one with.' },
  { icon: 'clock', title: 'Honest data freshness', body: 'Private-market data goes stale. Every listing carries a last-checked timestamp and links to its source, so you always know what you’re looking at and how old it is.' },
  { icon: 'eye', title: 'Human oversight of AI', body: 'The agents that scan, summarise and flag deals are reviewed by humans on anything consequential, and every output is logged and auditable.' },
  { icon: 'doc', title: 'Risk on the surface', body: 'Risk warnings sit on every page, not behind a link. Deal summaries state what could go wrong before what could go right.' },
  { icon: 'ban', title: 'No manufactured urgency', body: 'Deadlines shown on Bundle are the venue’s real deadlines. We add no countdown theatre, no “only £12k left!” bars, no confetti, no streaks.' },
];

const protections = [
  { icon: 'shield', title: 'The venue’s regulatory permissions', body: 'Crowdfunding platforms and secondary marketplaces operate under their own authorisations (FCA in the UK, SEC/FINRA in the US). Your money moves under their rules, not ours.' },
  { icon: 'wallet', title: 'The venue’s custody arrangements', body: 'Shares and client money are held by the venue’s nominee and custody structures. Bundle holds neither, ever.' },
  { icon: 'timer', title: 'The venue’s investor protections', body: 'Appropriateness tests, cooling-off periods and eligibility checks are run by the venue at the point of investment — as regulation intends.' },
  { icon: 'alert', title: 'What no one can protect you from', body: 'Company failure, illiquidity and dilution. They’re inherent to the asset class on every venue, and no aggregator changes that.' },
];

const phases = [
  {
    phase: 'Phase 1',
    title: 'Pure aggregation',
    body: 'Discovery, comparison, watchlists and portfolio tracking — activities that don’t require FCA authorisation, run with financial-promotion rules in mind and legal counsel on speed dial.',
    status: 'The launch path',
  },
  {
    phase: 'Phase 2',
    title: 'Authorised distribution',
    body: 'Where deeper routing — pre-filled orders, promoting specific deals — constitutes regulated activity, it ships only under FCA permissions or a partnership with an authorised firm.',
    status: 'In preparation',
  },
  {
    phase: 'Phase 3',
    title: 'Embedded execution',
    body: 'Venue API integrations that complete the trade without leaving Bundle, under whichever permissions that requires. The screen stays neutral; the plumbing gets shorter.',
    status: 'The destination',
  },
];
---

<BaseLayout
  title="Trust & Safety"
  description="How Bundle keeps the tape honest: neutral ranking, no markups, timestamped data, human oversight of AI, and a clear line on where regulatory protection actually comes from."
>
  <PageHero
    eyebrow="Trust & Safety"
    title='An aggregator is only useful if you can <em class="serif-aside">trust the screen.</em>'
    lead="Skyscanner works because nobody suspects the results are rigged. Bundle holds itself to the same bar: neutral ranking, no markups, honest data and risk kept on the surface."
  >
    <Fragment slot="actions">
      <a href="#principles" class="btn btn-primary btn-lg">The house rules <span class="arrow">→</span></a>
      <a href="/legal/risk-warning" class="btn btn-ghost btn-lg">Read the risk warning</a>
    </Fragment>
  </PageHero>

  <!-- Principles -->
  <section class="section" id="principles">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">House rules</p>
        <h2 class="h2 reveal" style="--d:.05s">Six rules the screen never breaks</h2>
      </div>
      <div class="grid cols-3">
        {
          principles.map((p, i) => (
            <article class="card card-hover reveal" style={`--d:${(i % 3) * 0.07}s`}>
              <span class="icon-chip"><Icon name={p.icon} /></span>
              <h3 class="h3" style="margin-top:1.1rem">{p.title}</h3>
              <p class="small muted" style="margin-bottom:0">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Where protection comes from -->
  <section class="section section-ink grain">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The honest map</p>
        <h2 class="h2 reveal" style="--d:.05s">Where your protection actually comes from</h2>
        <p class="lead reveal" style="--d:.1s">
          Because you invest on the listing venue, the regulatory protections
          are the venue's. Knowing exactly whose rules cover you is itself a
          protection — so we spell it out.
        </p>
      </div>
      <div class="grid cols-2">
        {
          protections.map((p, i) => (
            <article class="prot-card reveal" style={`--d:${i * 0.06}s`}>
              <span class="icon-chip"><Icon name={p.icon} size={19} /></span>
              <div>
                <h3 class="prot-title">{p.title}</h3>
                <p class="small" style="margin:0;color:#a9bcc7">{p.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Regulatory path -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Regulatory path</p>
        <h2 class="h2 reveal" style="--d:.05s">Built to grow into regulation, not around it</h2>
      </div>
      <div class="grid cols-3">
        {
          phases.map((ph, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="badge badge-teal mono">{ph.phase}</span>
              <h3 class="h3" style="margin-top:0.9rem">{ph.title}</h3>
              <p class="small muted">{ph.body}</p>
              <span class="badge badge-line">{ph.status}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    title="Neutrality is <em>the product.</em>"
    sub="If you ever catch the screen bending, tell us — that's the whole company on the line."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>

<style>
  .prot-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.4rem;
    border: 1px solid var(--line-2);
    border-radius: var(--r-m);
    background: rgba(255, 255, 255, 0.015);
  }

  .prot-title {
    margin: 0 0 0.35rem;
    color: #fff;
    font-size: 1.05rem;
  }
</style>
