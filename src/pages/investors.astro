---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';

const features = [
  { icon: 'activity', title: 'One tape, three markets', body: 'Crowdfunding rounds, secondary blocks and pre-IPO offers stream into a single screener instead of a dozen tabs and newsletters.' },
  { icon: 'bell', title: 'Alerts that hit first', body: 'A block lists below the last round. A raise crosses 90% funded. A liquidity window opens on a name you hold. You know within minutes.' },
  { icon: 'scale', title: 'Venue-by-venue comparison', body: 'Price, fees, minimums, share class and access rules, side by side — so the venue you execute on is a decision, not a default.' },
  { icon: 'pie', title: 'One portfolio, every venue', body: 'Positions on Crowdcube, Republic, Forge, Hiive and beyond, tracked in one P&L with revaluations as new rounds price.' },
  { icon: 'eye', title: 'Watchlists on companies, not platforms', body: 'Follow the company once. Wherever its shares surface next — any venue, any structure — it shows up on your tape.' },
  { icon: 'sliders', title: 'Screens that keep working', body: 'Save a screen — “UK fintech secondaries under £2k minimum” — and Bundle keeps running it while you sleep.' },
];

const alerts = [
  { kind: 'down', icon: '▼', text: 'ANTH — block listed 6% below last round', src: 'Forge Global', time: '2m' },
  { kind: 'up', icon: '▲', text: 'Aurora Fusion crossed 84% funded', src: 'Crowdcube', time: '18m' },
  { kind: 'flat', icon: '◆', text: 'PISCES window announced: UK fintech you follow', src: 'LSE PSM', time: '1h' },
  { kind: 'up', icon: '▲', text: 'REV — new high on the secondary tape', src: 'Hiive', time: '3h' },
];
---

<BaseLayout
  title="For Investors"
  description="Why investors run their private-market deal flow through Bundle: one screener, cross-venue alerts, side-by-side comparison and a single portfolio."
>
  <PageHero
    eyebrow="For investors"
    title="Your unfair advantage <em>in private markets.</em>"
    lead="Public-market traders get one terminal for everything. Private-market investors get scattered tabs and stale newsletters. Bundle fixes your side of that."
  >
    <a slot="actions" href="/deals" class="btn btn-primary btn-lg">Start scanning <span class="arrow">→</span></a>
    <a slot="actions" href="/waitlist" class="btn btn-ghost btn-lg">Get early access</a>

    <div slot="visual" class="alerts-panel panel" aria-hidden="true">
      <header class="ap-head">
        <span class="ap-title mono"><span class="live-dot"></span> Alert stream</span>
        <span class="ap-badge mono">4 new</span>
      </header>
      <ul class="ap-list">
        {
          alerts.map((a) => (
            <li class="ap-row">
              <span class:list={['ap-ico', 'px', a.kind]}>{a.icon}</span>
              <span class="ap-body">
                <span class="ap-text">{a.text}</span>
                <span class="ap-meta">{a.src} · {a.time} ago</span>
              </span>
            </li>
          ))
        }
      </ul>
      <footer class="ap-foot mono">Illustrative alerts, demo data</footer>
    </div>
  </PageHero>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The toolkit</p>
        <h2 class="h2 reveal" style="--d:.05s">Everything between you and the trade, compressed</h2>
      </div>
      <div class="grid cols-3">
        {
          features.map((f, i) => (
            <article class="card card-hover reveal" style={`--d:${(i % 3) * 0.07}s`}>
              <span class="icon-chip"><Icon name={f.icon} /></span>
              <h3 class="h3" style="margin-top:1.1rem">{f.title}</h3>
              <p class="small muted" style="margin-bottom:0">{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Honesty strip -->
  <section class="section tight section-tint-full">
    <div class="container narrow">
      <div class="panel-tint honesty reveal">
        <Icon name="shield" size={22} />
        <p>
          Bundle shows you the market; it doesn't pick your investments, hold
          your money or soften the risks. Private-market deals are illiquid and
          high-risk on every venue — you can lose everything you put in.
          <a href="/legal/risk-warning">Two minutes on the risks</a>.
        </p>
      </div>
    </div>
  </section>

  <CTABand
    title="Trade the whole market, <em>not one platform's shelf.</em>"
    sub="Screener, watchlists and cross-venue alerts — free for investors, from day one."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse live deals"
    secondaryHref="/deals"
  />
</BaseLayout>

<style>
  .alerts-panel {
    overflow: hidden;
    box-shadow: var(--shadow-l), 0 0 70px -28px rgba(31, 210, 192, 0.3);
  }

  .ap-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--line);
    background: #0b111c;
  }

  .ap-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-2);
  }

  .ap-badge {
    font-size: 0.68rem;
    color: var(--teal);
    background: rgba(31, 210, 192, 0.1);
    border: 1px solid rgba(31, 210, 192, 0.25);
    border-radius: 999px;
    padding: 0.12rem 0.55rem;
  }

  .ap-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ap-row {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }

  .ap-row:last-child {
    border-bottom: 0;
  }

  .ap-ico {
    flex: none;
    font-size: 0.7rem;
    margin-top: 0.2rem;
  }

  .ap-ico.up { color: var(--up); }
  .ap-ico.down { color: var(--down); }
  .ap-ico.flat { color: var(--sand-ink); }

  .ap-body {
    display: grid;
    gap: 0.1rem;
  }

  .ap-text {
    font-size: 0.9rem;
    font-weight: 550;
    color: var(--ink);
    line-height: 1.4;
  }

  .ap-meta {
    font-size: 0.74rem;
    color: var(--faint);
  }

  .ap-foot {
    padding: 0.55rem 1.1rem;
    border-top: 1px solid var(--line);
    background: #0b111c;
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .honesty {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.4rem 1.6rem;
  }

  .honesty :global(svg) {
    color: var(--teal);
    flex: none;
    margin-top: 0.15rem;
  }

  .honesty p {
    margin: 0;
    font-size: 0.95rem;
  }
</style>
