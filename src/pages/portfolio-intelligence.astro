---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';
import DashboardMockup from '../components/DashboardMockup.astro';

const modules = [
  { icon: 'pie', title: 'One P&L, every venue', body: 'Positions from Crowdcube, Republic, Forge, Hiive and beyond, unified into a single portfolio with cost basis and current marks.' },
  { icon: 'pulse', title: 'Revaluation events', body: 'When a company you hold raises a new round or trades on a secondary venue, your position re-marks — with the source shown, never a black box.' },
  { icon: 'bars', title: 'Exposure breakdowns', body: 'Sector, stage, venue and geography splits, so you can see when “diversified” has quietly become five fintech positions.' },
  { icon: 'calendar', title: 'Liquidity calendar', body: 'Tender windows, PISCES auctions and secondary listings relevant to names you hold, laid out as a calendar instead of a surprise.' },
  { icon: 'award', title: 'SEIS/EIS tracker', body: 'For UK crowdfunding positions: which holdings qualify, which certificates are in, and reminders that tax treatment depends on your circumstances.' },
  { icon: 'bell', title: 'Position alerts', body: 'Follow-on rounds, dilution notices, valuation moves and honest failure alerts when a company dissolves. No noise, no spin.' },
  { icon: 'gauge', title: 'Concentration check', body: 'A running answer to “how concentrated am I?” — with a nudge when a single name or theme starts to dominate.' },
  { icon: 'spark', title: 'Plain-English recaps', body: 'A monthly readable summary of what actually happened across your portfolio, sourced and linked, generated by the AI engine.' },
];

const lifecycle = [
  { label: 'Execute', body: 'You invest on the venue; the position lands in Bundle with its documents and cost basis' },
  { label: 'Hold', body: 'Revaluations, dilution events and disclosure updates stream in from every venue' },
  { label: 'Liquidity', body: 'Tenders, windows and secondary listings for your names surface as they open' },
  { label: 'Exit', body: 'Sales, IPOs and failures recorded honestly — realised P&L, not vibes' },
];
---

<BaseLayout
  title="Portfolio Intelligence"
  description="One portfolio across every private-market venue: unified P&L, revaluation events, exposure breakdowns, liquidity calendar and honest alerts."
>
  <section class="pi-hero bg-grid">
    <div class="container">
      <div class="section-head center" style="margin-bottom:2.5rem">
        <p class="eyebrow no-rule reveal">Portfolio Intelligence</p>
        <h1 class="display reveal" style="--d:.06s">
          Trade on many venues.<br />
          <em class="serif-aside">Hold one portfolio.</em>
        </h1>
        <p class="lead mx-auto reveal" style="--d:.12s">
          The cost of shopping the whole market used to be a spreadsheet with
          nine tabs. Bundle folds every venue's positions into one P&L that
          keeps working for the decade you hold them.
        </p>
        <div class="hero-actions-c reveal" style="--d:.18s">
          <a href="/waitlist" class="btn btn-primary btn-lg">Get early access <span class="arrow">→</span></a>
          <a href="/ai-engine" class="btn btn-ghost btn-lg">The engine behind it</a>
        </div>
      </div>
      <div class="reveal" style="--d:.22s">
        <DashboardMockup variant="full" />
        <p class="mock-caption">Product concept: illustrative portfolio and companies, not a live account or recommendations.</p>
      </div>
    </div>
  </section>

  <!-- Modules -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The modules</p>
        <h2 class="h2 reveal" style="--d:.05s">Everything a cross-venue position needs</h2>
      </div>
      <div class="grid cols-4">
        {
          modules.map((m, i) => (
            <article class="card card-hover reveal" style={`--d:${(i % 4) * 0.06}s`}>
              <span class="icon-chip"><Icon name={m.icon} size={19} /></span>
              <h3 class="mod-title">{m.title}</h3>
              <p class="small muted" style="margin:0">{m.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Lifecycle -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The long game</p>
        <h2 class="h2 reveal" style="--d:.05s">Private positions live for years. So does the tracking.</h2>
      </div>
      <div class="grid cols-4">
        {
          lifecycle.map((l, i) => (
            <div class="life-card reveal" style={`--d:${i * 0.07}s`}>
              <span class="life-label mono">{l.label}</span>
              <p class="small muted" style="margin:0.5rem 0 0">{l.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    title="Your whole private portfolio, <em>finally legible.</em>"
    sub="Portfolio sync ships with early access, free for investors."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse live deals"
    secondaryHref="/deals"
  />
</BaseLayout>

<style>
  .pi-hero {
    padding-block: clamp(3.5rem, 8vw, 6rem) clamp(2.5rem, 6vw, 4.5rem);
    border-bottom: 1px solid var(--line);
  }

  .hero-actions-c {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .mock-caption {
    margin-top: 0.8rem;
    font-size: 0.75rem;
    color: var(--faint);
    text-align: center;
  }

  .mod-title {
    font-size: 1.02rem;
    margin: 0.9rem 0 0.35rem;
  }

  .life-card {
    padding: 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--r-m);
    background: var(--surface);
  }

  .life-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
  }
</style>
