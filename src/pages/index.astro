---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import DashboardMockup from '../components/DashboardMockup.astro';
import ConcentrationMeter from '../components/ConcentrationMeter.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import Stat from '../components/Stat.astro';
import LogoCloud from '../components/LogoCloud.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const problems = [
  {
    icon: 'target',
    title: 'Concentrated bets',
    body: 'Most retail investors back one or two startups and hope. Professionals expect most bets to fail, so they spread capital across twenty or more.',
  },
  {
    icon: 'pulse',
    title: 'Hype-driven decisions',
    body: 'Campaign marketing rewards recognisable brands and charismatic founders, not fundamentals. Familiarity is not diligence.',
  },
  {
    icon: 'eye',
    title: 'The post-investment black box',
    body: 'After you invest, updates are sporadic and unstructured. Public-market investors get analytics and alerts; private investors get silence.',
  },
];

const shiftRows = [
  { left: 'Deal-led user experience', right: 'Portfolio-education-led experience' },
  { left: 'Optimise fundraising volume', right: 'Optimise investor understanding and outcomes' },
  { left: 'Campaign marketplaces', right: 'Portfolio decision infrastructure' },
  { left: 'Transaction-focused', right: 'Wealth-journey focused' },
  { left: 'Education as a compliance checkbox', right: 'Education as the product itself' },
];

const steps = [
  {
    num: '01',
    icon: 'users',
    title: 'Profile & appropriateness',
    body: 'A risk profile and an FCA-style appropriateness test come first. If startup investing isn’t right for you yet, we say so.',
  },
  {
    num: '02',
    icon: 'graduation',
    title: 'Learn the portfolio logic',
    body: 'Short, plain-English modules: why startups fail, why diversification matters, what dilution and illiquidity really mean.',
  },
  {
    num: '03',
    icon: 'sliders',
    title: 'Build diversified exposure',
    body: 'Choose companies and allocation sizes yourself, from £10–£50 per company, guided by educational frameworks, never pushed.',
  },
  {
    num: '04',
    icon: 'gauge',
    title: 'Monitor with portfolio intelligence',
    body: 'Concentration alerts, dilution tracking, follow-on notifications and AI plain-English summaries, for the whole life of your portfolio.',
  },
];

const frameworks = [
  { icon: 'spark', name: 'UK AI & Automation', desc: 'Applied AI, infrastructure and automation companies' },
  { icon: 'seedling', name: 'Climate Tech', desc: 'Energy, materials and decarbonisation' },
  { icon: 'building', name: 'University Spinout', desc: 'Research-born companies from UK labs' },
  { icon: 'users', name: 'Female Founder', desc: 'Companies with women on the founding team' },
  { icon: 'layers', name: 'B2B SaaS', desc: 'Recurring-revenue software businesses' },
  { icon: 'coins', name: 'Consumer Brand', desc: 'Products with retail traction and community' },
  { icon: 'pulse', name: 'Early-Stage High-Risk', desc: 'Pre-seed exposure, highest failure rates' },
  { icon: 'bars', name: 'Later-Stage Growth', desc: 'Revenue-stage companies, lower dispersion' },
];

const tiers = [
  { name: 'Conservative Starter', color: 'var(--ramp1)', desc: 'Later-stage, revenue traction, smaller example allocations' },
  { name: 'Balanced Innovation', color: 'var(--ramp2)', desc: 'Seed and venture mix, how 10–20 positions build over time' },
  { name: 'High-Risk Frontier', color: 'var(--ramp4)', desc: 'AI, deeptech and spinouts, higher friction, stronger warnings' },
  { name: 'Impact', color: 'var(--sage)', desc: 'Climate, health and social infrastructure with impact literacy' },
];

const agents = [
  { icon: 'doc-check', name: 'Founder Pitch Agent', desc: 'Scores pitch clarity, traction and valuation reasonableness' },
  { icon: 'gauge', name: 'Startup Risk Agent', desc: 'Risk bands with plain-English explanations and benchmarks' },
  { icon: 'pie', name: 'Portfolio Simulation Agent', desc: 'Test allocations and see concentration before you commit' },
  { icon: 'graduation', name: 'Investor Education Agent', desc: 'Adapts lessons to the mistakes you actually make' },
  { icon: 'shield', name: 'Suitability & Vulnerability Agent', desc: 'Flags unsuitable journeys for human review' },
  { icon: 'search', name: 'Fraud & Anomaly Agent', desc: 'Monitors claims, financials and adverse media' },
];

const fronts = [
  {
    icon: 'seedling',
    title: 'Equity crowdfunding',
    body: 'Primary rounds in vetted UK startups, the deal flow you build your first portfolio from.',
    href: '/investors',
    label: 'For investors',
  },
  {
    icon: 'exchange',
    title: 'Secondary Market',
    body: 'Structured, scheduled liquidity windows for private shares, built for the UK’s PISCES era.',
    href: '/secondary-market',
    label: 'The liquidity story',
  },
  {
    icon: 'layers',
    title: 'SPVs & Pre-IPO Funds',
    body: 'Pooled vehicles and one-click diversified baskets, designed to lower minimums even further.',
    href: '/spvs-and-funds',
    label: 'Diversified access',
  },
];

const trust = [
  { icon: 'graduation', label: 'Mandatory education first' },
  { icon: 'doc-check', label: 'Appropriateness tests' },
  { icon: 'timer', label: 'Cooling-off periods' },
  { icon: 'gauge', label: 'Concentration alerts' },
  { icon: 'ban', label: 'No gamified nudges' },
  { icon: 'eye', label: 'Human oversight of AI' },
];
---

<BaseLayout
  title="Bundle.ai, Build a startup portfolio, like a professional"
  description="Bundle.ai teaches retail investors to build diversified startup portfolios with the discipline professionals use, education-first, FCA-conscious, from £10 per company."
>
  <!-- ============ 1. HERO ============ -->
  <section class="hero bg-grid">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow no-rule reveal">Private markets · discipline by design</p>
          <h1 class="display reveal" style="--d:.05s">
            Build a startup portfolio, <em class="serif-aside">like a professional.</em>
          </h1>
          <p class="lead reveal" style="--d:.11s">
            Most platforms sell you single startup bets. Bundle teaches you to spread
            small amounts, £10 to £50 per company, across many startups, with the
            diversification discipline professional investors rely on. You stay in
            control. We keep it honest.
          </p>
          <div class="hero-actions reveal" style="--d:.17s">
            <a href="/waitlist" class="btn btn-primary btn-lg">Join the waitlist <span class="arrow">→</span></a>
            <a href="/how-it-works" class="btn btn-ghost btn-lg">See how it works</a>
          </div>
          <ul class="trust-row reveal" style="--d:.23s">
            <li><Icon name="shield" size={15} /> FCA-conscious by design</li>
            <li><Icon name="graduation" size={15} /> Education-first</li>
            <li><Icon name="coins" size={15} /> Low minimums</li>
          </ul>
        </div>
        <div class="hero-visual reveal" style="--d:.2s">
          <DashboardMockup variant="hero" />
          <p class="mockup-caption">Product concept, illustrative portfolio, not a live account.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 2. THE PROBLEM ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow reveal">The problem</p>
        <h2 class="h2 reveal" style="--d:.05s">
          <span class="serif-aside">“Retail investors behave like gamblers.<br class="desk-only" />
          Professional investors behave like portfolio managers.”</span>
        </h2>
        <p class="lead mx-auto reveal" style="--d:.1s">
          The gap isn't access any more, UK crowdfunding solved that a decade ago.
          The gap is behaviour, and it shows up in three ways.
        </p>
      </div>
      <div class="grid cols-3">
        {
          problems.map((p, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="icon-chip"><Icon name={p.icon} /></span>
              <h3 class="h3 card-title">{p.title}</h3>
              <p class="small muted">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ 3. THE SHIFT ============ -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The shift</p>
        <h2 class="h2 reveal" style="--d:.05s">From deal-led to portfolio-led</h2>
        <p class="lead reveal" style="--d:.1s">
          Traditional platforms democratised <strong>access</strong> to startup
          investing. Bundle democratises the <strong>education, tools and
          discipline</strong> behind venture-style portfolio strategy.
        </p>
      </div>
      <ComparisonTable rows={shiftRows} />
    </div>
  </section>

  <!-- ============ 4. HOW IT WORKS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow reveal">How it works</p>
        <h2 class="h2 reveal" style="--d:.05s">Discipline by design, not by willpower</h2>
        <p class="lead mx-auto reveal" style="--d:.1s">
          Four stages, in a deliberate order. Education and appropriateness come
          before any investing, that friction is the point.
        </p>
      </div>
      <div class="steps-grid">
        {
          steps.map((s, i) => (
            <article class="step-card card card-hover reveal" style={`--d:${i * 0.08}s`}>
              <div class="step-top">
                <span class="step-index mono">{s.num}</span>
                <span class="icon-chip"><Icon name={s.icon} /></span>
              </div>
              <h3 class="h3 card-title">{s.title}</h3>
              <p class="small muted">{s.body}</p>
            </article>
          ))
        }
      </div>
      <p class="center reveal" style="margin-top:2.25rem">
        <a class="text-link" href="/how-it-works">Walk through the full journey <span class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ============ 5. CONCENTRATION METER SPOTLIGHT ============ -->
  <section class="section section-ink meter-spotlight bg-wash">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow reveal" style="color:#7fc6cf">Signature feature</p>
          <h2 class="h2 reveal" style="--d:.05s">How concentrated am I?</h2>
          <p class="reveal" style="--d:.1s">
            One honest gauge, answered continuously: are you making isolated bets,
            or building a portfolio? The concentration meter sits at the heart of
            every Bundle dashboard, no major UK retail platform offers it.
          </p>
          <p class="reveal" style="--d:.14s">
            Watch it move as a demo portfolio grows. One position is a gamble.
            Twenty small ones are a strategy.
          </p>
          <ul class="check-list light reveal" style="--d:.18s">
            <li>
              <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
              <span>Concentration alerts when one position dominates</span>
            </li>
            <li>
              <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
              <span>Educational maximum-exposure warnings, tuned to your profile</span>
            </li>
            <li>
              <span class="tick"><Icon name="check" size={11} stroke={2.6} /></span>
              <span>Sector, stage and geography balance at a glance</span>
            </li>
          </ul>
        </div>
        <div class="meter-demo-card reveal" style="--d:.15s">
          <ConcentrationMeter interactive positions={1} />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 6. EDUCATIONAL FRAMEWORKS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Educational portfolio frameworks</p>
        <h2 class="h2 reveal" style="--d:.05s">Understand the exposure before you pick the companies</h2>
        <p class="lead reveal" style="--d:.1s">
          Bundle opens with a different question: <em class="serif-aside">what type of
          startup exposure are you trying to build?</em> Frameworks teach the logic of
          a theme, then you choose every company and allocation yourself.
        </p>
      </div>

      <div class="grid cols-4">
        {
          frameworks.map((f, i) => (
            <article class="card card-hover fw-card reveal" style={`--d:${(i % 4) * 0.06}s`}>
              <span class="icon-chip"><Icon name={f.icon} size={19} /></span>
              <h3 class="fw-name">{f.name}</h3>
              <p class="small muted fw-desc">{f.desc}</p>
            </article>
          ))
        }
      </div>

      <div class="tiers reveal">
        <p class="tiers-label mono">Educational risk tiers</p>
        <div class="grid cols-4">
          {
            tiers.map((t) => (
              <div class="tier-card card">
                <span class="tier-bar" style={`background:${t.color}`}></span>
                <h3 class="fw-name">{t.name}</h3>
                <p class="small muted fw-desc">{t.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <p class="framework-note reveal">
        <Icon name="info" size={16} />
        Frameworks are educational structures, not managed portfolios, model
        portfolios or investment advice. You make every decision yourself.
      </p>
    </div>
  </section>

  <!-- ============ 7. AI ENGINE TEASER ============ -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The Bundle AI Engine</p>
        <h2 class="h2 reveal" style="--d:.05s">
          Six agents working in the background.<br />Zero of them pick stocks for you.
        </h2>
        <p class="lead reveal" style="--d:.1s">
          AI-assisted diligence, education and portfolio intelligence, explainable,
          logged, and supervised by humans. Never a black box, never “you should
          invest £X.”
        </p>
      </div>
      <div class="grid cols-3">
        {
          agents.map((a, i) => (
            <a href="/ai-engine" class="agent-mini card card-hover reveal" style={`--d:${(i % 3) * 0.07}s`}>
              <span class="icon-chip"><Icon name={a.icon} size={19} /></span>
              <span>
                <span class="agent-mini-name">{a.name}</span>
                <span class="small muted">{a.desc}</span>
              </span>
            </a>
          ))
        }
      </div>
      <p class="center reveal" style="margin-top:2.25rem">
        <a class="text-link" href="/ai-engine">Meet the engine, and its governance <span class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ============ 8. THREE FRONTS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow reveal">Where this goes</p>
        <h2 class="h2 reveal" style="--d:.05s">Crowdfunding is the door we open first, <br class="desk-only" /> not the destination</h2>
        <p class="lead mx-auto reveal" style="--d:.1s">
          The same engine, education, risk scoring, enforced diversification,
          monitoring, extends across three fronts of private-market access.
        </p>
      </div>
      <div class="grid cols-3">
        {
          fronts.map((f, i) => (
            <a href={f.href} class="card card-hover front-card reveal" style={`--d:${i * 0.08}s`}>
              <span class="icon-chip"><Icon name={f.icon} /></span>
              <h3 class="h3 card-title">{f.title}</h3>
              <p class="small muted">{f.body}</p>
              <span class="text-link front-link">{f.label} <span class="arrow">→</span></span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ 9. FOR FOUNDERS STRIP ============ -->
  <section class="section founders-strip section-tint">
    <div class="container">
      <div class="split wide-left">
        <div>
          <p class="eyebrow reveal">For founders</p>
          <h2 class="h2 reveal" style="--d:.05s">Raise from informed, portfolio-aware investors</h2>
          <p class="lead reveal" style="--d:.1s">
            Technical, B2B and deeptech founders are underserved by consumer-brand
            crowdfunding. Bundle brings you investors who understand failure rates,
            timelines and dilution, and AI tooling that gets you raise-ready.
          </p>
          <div class="hero-actions reveal" style="--d:.15s">
            <a href="/founders" class="btn btn-primary">For Founders <span class="arrow">→</span></a>
            <a href="/founders#health-check" class="btn btn-ghost">Free AI Pitch Health Check</a>
          </div>
        </div>
        <div class="pitch-mini card reveal" style="--d:.12s" aria-hidden="true">
          <div class="pm-head">
            <span class="icon-chip"><Icon name="doc-check" size={19} /></span>
            <div>
              <span class="pm-title">Pitch Health Check</span>
              <span class="pm-sub mono">caldera-robotics-deck.pdf</span>
            </div>
            <span class="badge badge-sage pm-score">72 / 100</span>
          </div>
          <div class="pm-rows">
            <div class="pm-row"><span>Clarity of proposition</span><span class="pm-track"><span style="width:84%;background:var(--c4)"></span></span></div>
            <div class="pm-row"><span>Traction evidence</span><span class="pm-track"><span style="width:66%;background:var(--c1)"></span></span></div>
            <div class="pm-row"><span>Valuation reasonableness</span><span class="pm-track"><span style="width:48%;background:var(--c2)"></span></span></div>
            <div class="pm-row"><span>SEIS/EIS readiness</span><span class="pm-track"><span style="width:90%;background:var(--c4)"></span></span></div>
          </div>
          <p class="pm-note">3 likely investor questions · 2 missing disclosures · 1 red flag</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 10. WHY NOW ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Why now</p>
        <h2 class="h2 reveal" style="--d:.05s">The rules, the maths and the market all just changed</h2>
      </div>
      <div class="grid cols-3 why-grid">
        <div class="why-card reveal">
          <Stat value={10.8} decimals={1} prefix="£" suffix="bn" label="UK small-business equity, 2024" note="Private investing is healthy, it's the deal-led crowdfunding model that shrank. We're building the disciplined version that replaces it." />
        </div>
        <div class="why-card reveal" style="--d:.08s">
          <div class="stat">
            <div class="date-stat">19 Jan <span data-count="2026" data-plain>0</span></div>
            <div class="date-label">The Public Offer Platform regime</div>
            <div class="date-note">
              In force since January 2026: platforms must vet companies and warn
              investors. Rules we'd have chosen anyway, for us they're features,
              not burdens.
            </div>
          </div>
        </div>
        <div class="why-card reveal" style="--d:.16s">
          <Stat value={10} prefix="£" label="Minimum that finally makes sense" note="AI-assisted diligence and monitoring collapse the per-position labour that forced other platforms to choose between low fees and low minimums." />
        </div>
      </div>
      <p class="small muted reveal" style="margin-top:1.5rem;max-width:52rem">
        Sources: British Business Bank Small Business Equity Tracker 2025; FCA
        PS25/10 (Public Offer Platforms). Bundle's stat counters stop at real
        numbers, no invented traction here.
      </p>
    </div>
  </section>

  <!-- ============ 11. TRUST BAND ============ -->
  <section class="section tight trust-band-wrap">
    <div class="container">
      <div class="trust-band panel-tint reveal">
        <div class="trust-head">
          <h2 class="h3">Investor safety isn't an appendix. It's the moat.</h2>
          <a class="text-link" href="/trust">Trust & Safety <span class="arrow">→</span></a>
        </div>
        <ul class="trust-icons">
          {
            trust.map((t) => (
              <li>
                <span class="icon-chip"><Icon name={t.icon} size={19} /></span>
                <span>{t.label}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ 12. ECOSYSTEM ============ -->
  <section class="section tight">
    <div class="container">
      <LogoCloud />
    </div>
  </section>

  <!-- ============ 13. FINAL CTA + WAITLIST ============ -->
  <section class="section final-cta bg-grid">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow reveal">Early access</p>
          <h2 class="h2 reveal" style="--d:.05s">
            One bet is a gamble.<br /><em class="serif-aside">Twenty is a strategy.</em>
          </h2>
          <p class="lead reveal" style="--d:.1s">
            Join the waitlist for early access to the UK's first portfolio-first
            startup investing platform. Learn free in the Academy while you wait.
          </p>
        </div>
        <div class="card waitlist-card reveal" style="--d:.12s">
          <h3 class="h3">Join the waitlist</h3>
          <p class="small muted">Investor or founder, early access opens in order of sign-up.</p>
          <WaitlistForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(3.5rem, 7vw, 6rem) clamp(3.5rem, 7vw, 6rem);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }

  .hero-copy .display em {
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.9rem;
  }

  .trust-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.6rem;
    padding: 0;
    margin: 2rem 0 0;
    font-size: 0.875rem;
    color: var(--text-2);
  }

  .trust-row li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .trust-row svg {
    color: var(--teal);
  }

  .hero-visual {
    position: relative;
  }

  .mockup-caption {
    margin-top: 0.8rem;
    font-size: 0.75rem;
    color: var(--faint);
    text-align: right;
  }

  @media (max-width: 1023px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Cards general */
  .card-title {
    margin-top: 1.1rem;
  }

  .card .small:last-child {
    margin-bottom: 0;
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .step-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .step-index {
    font-size: 0.8rem;
    color: var(--faint);
    letter-spacing: 0.08em;
  }

  @media (max-width: 1000px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .steps-grid { grid-template-columns: 1fr; }
  }

  /* Meter spotlight */
  .meter-spotlight :global(.lead),
  .meter-spotlight p {
    color: #b8cdd1;
  }

  .meter-spotlight .h2 {
    color: #fff;
  }

  .check-list.light {
    margin-top: 1.6rem;
  }

  .check-list.light span:last-child {
    color: #d7e5e7;
  }

  .check-list.light .tick {
    background: rgba(55, 169, 140, 0.2);
    color: #7ed4bc;
  }

  .meter-demo-card {
    background: var(--surface);
    border-radius: var(--r-l);
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    box-shadow: var(--shadow-l);
    font-size: 1.35rem; /* scales meter internals (em-based) */
  }

  .meter-demo-card :global(.meter-label),
  .meter-demo-card :global(.meter-scale) {
    font-size: 0.85rem;
  }

  /* Frameworks */
  .fw-card,
  .tier-card {
    padding: 1.35rem;
  }

  .fw-name {
    font-size: 1.02rem;
    margin: 0.9rem 0 0.3rem;
    font-weight: 600;
    color: var(--ink);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .fw-desc {
    margin: 0;
  }

  .tiers {
    margin-top: 2rem;
