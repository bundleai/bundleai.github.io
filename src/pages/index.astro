---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Ticker from '../components/Ticker.astro';
import DealCard from '../components/DealCard.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import { deals, platforms, fmtPrice, fmtChange, platformName } from '../data/deals';

const trending = deals.filter((d) => d.trending).slice(0, 4);
const closingSoon = deals
  .filter((d) => d.type === 'crowdfunding' && d.closes)
  .sort((a, b) => parseInt(a.closes!) - parseInt(b.closes!))
  .slice(0, 3);

const boardTabs = [
  { id: 'all', label: 'All markets', rows: deals.slice(0, 7) },
  { id: 'cf', label: 'Crowdfunding', rows: deals.filter((d) => d.type === 'crowdfunding').slice(0, 7) },
  { id: 'sec', label: 'Secondaries', rows: deals.filter((d) => d.type === 'secondary').slice(0, 7) },
  { id: 'pre', label: 'Pre-IPO', rows: deals.filter((d) => d.type === 'pre-ipo').slice(0, 7) },
];

const steps = [
  {
    icon: 'search',
    title: 'Discover',
    body: 'One search across every venue we track — crowdfunding rounds, secondary blocks and pre-IPO offers, side by side.',
  },
  {
    icon: 'scale',
    title: 'Compare',
    body: 'Same company, different venue, different price. See fees, minimums, share class and access requirements before you commit.',
  },
  {
    icon: 'exchange',
    title: 'Execute',
    body: 'Jump straight into the deal on the venue that listed it. Bundle tracks the position in your cross-platform portfolio.',
  },
];

const edges = [
  { icon: 'bell', title: 'Price & discount alerts', body: 'Get pinged when a block lists below the last round, or a raise nears its close.' },
  { icon: 'pie', title: 'One portfolio, every venue', body: 'Holdings on Crowdcube, Republic, Forge and beyond — tracked in a single P&L.' },
  { icon: 'sliders', title: 'Screener-grade filters', body: 'Filter the whole private market by sector, valuation, minimum ticket and venue.' },
];
---

<BaseLayout
  title="Bundle, Every private-market deal. One terminal."
  description="Bundle aggregates equity crowdfunding rounds, secondary blocks and pre-IPO offers from Crowdcube, Republic Europe, Wefunder, EquityZen, Forge and more — compare and invest in one place."
>
  <Ticker />

  <!-- ============ 1. HERO + MARKET BOARD ============ -->
  <section class="hero bg-grid">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow no-rule reveal"><span class="live-dot"></span> Live across 10 venues</p>
          <h1 class="display reveal" style="--d:.05s">
            Every private-market deal.<br /><span class="text-grad">One terminal.</span>
          </h1>
          <p class="lead reveal" style="--d:.11s">
            Crowdfunding rounds, secondary blocks and pre-IPO offers from
            Crowdcube, Republic Europe, Wefunder, EquityZen, Forge and more —
            screened, compared and one click from execution.
          </p>
          <form class="hero-search reveal" style="--d:.16s" action="/deals" method="get" role="search">
            <Icon name="search" size={18} />
            <input
              type="search"
              name="q"
              placeholder="Search a company, sector or venue…"
              aria-label="Search deals"
              autocomplete="off"
            />
            <button type="submit" class="btn btn-primary btn-sm">Scan the market</button>
          </form>
          <ul class="hero-stats reveal px" style="--d:.22s">
            <li><strong>{deals.length}</strong> live deals</li>
            <li><strong>{platforms.length}</strong> venues tracked</li>
            <li><strong>3</strong> market types</li>
          </ul>
        </div>

        <div class="hero-board reveal" style="--d:.18s">
          <div class="board panel" data-tabs>
            <header class="board-head">
              <span class="board-live"><span class="live-dot"></span> Market board</span>
              <div class="board-tabs" role="tablist" aria-label="Market type">
                {
                  boardTabs.map((t, i) => (
                    <button
                      type="button"
                      role="tab"
                      id={`tab-${t.id}`}
                      aria-controls={`panel-${t.id}`}
                      aria-selected={i === 0 ? 'true' : 'false'}
                      tabindex={i === 0 ? 0 : -1}
                    >
                      {t.label}
                    </button>
                  ))
                }
              </div>
            </header>
            {
              boardTabs.map((t, i) => (
                <div class="board-body" id={`panel-${t.id}`} role="tabpanel" aria-labelledby={`tab-${t.id}`} hidden={i !== 0}>
                  <ul class="board-rows">
                    {t.rows.map((d) => (
                      <li>
                        <a href={`/deals#${d.id}`} class="board-row">
                          <span class="br-avatar" style={`--h: var(--${d.hue})`}>{d.name.split(/\s+/).map((w) => w[0]).join('').slice(0, 2)}</span>
                          <span class="br-id">
                            <span class="br-name">{d.name}</span>
                            <span class="br-src">{platformName(d.platform)} · {d.sector}</span>
                          </span>
                          {d.progress != null ? (
                            <span class="br-prog">
                              <span class="prog"><span style={`width:${Math.min(d.progress, 100)}%`} /></span>
                              <span class="br-prog-label px">{d.progress}% funded</span>
                            </span>
                          ) : (
                            <span class="br-val px">{d.valuation}</span>
                          )}
                          <span class="br-price px">{fmtPrice(d)}</span>
                          <span class:list={['br-change', 'px', d.change > 0 ? 'up' : d.change < 0 ? 'down' : 'flat']}>
                            {d.change !== 0 ? fmtChange(d) : d.closes ? `${d.closes} left` : '—'}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <footer class="board-foot">
                    <a href="/deals" class="text-link">Open the full screener <span class="arrow">→</span></a>
                  </footer>
                </div>
              ))
            }
          </div>
          <p class="board-caption">Illustrative deals and prices — not live quotes or financial promotions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 2. TRENDING ============ -->
  <section class="section tight">
    <div class="container">
      <div class="rail-head reveal">
        <h2 class="h3"><Icon name="pulse" size={18} /> Trending this week</h2>
        <a href="/deals" class="text-link small">All deals <span class="arrow">→</span></a>
      </div>
      <div class="grid cols-4">
        {trending.map((d, i) => <DealCard deal={d} class="reveal" style={`--d:${i * 0.06}s`} />)}
      </div>
    </div>
  </section>

  <!-- ============ 3. CLOSING SOON ============ -->
  <section class="section tight">
    <div class="container">
      <div class="rail-head reveal">
        <h2 class="h3"><Icon name="timer" size={18} /> Closing soon</h2>
        <a href="/deals?type=crowdfunding" class="text-link small">All crowdfunding <span class="arrow">→</span></a>
      </div>
      <div class="grid cols-3">
        {closingSoon.map((d, i) => <DealCard deal={d} class="reveal" style={`--d:${i * 0.06}s`} />)}
      </div>
    </div>
  </section>

  <!-- ============ 4. VENUES ============ -->
  <section class="section section-ink grain">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow reveal" style="justify-content:center">The aggregator</p>
        <h2 class="h2 reveal" style="--d:.05s">Think Skyscanner, for private markets</h2>
        <p class="lead mx-auto reveal" style="--d:.1s">
          The deals already exist — scattered across crowdfunding platforms,
          secondary marketplaces and pre-IPO desks. Bundle puts the whole market
          on one screen, then routes you to the venue to invest.
        </p>
      </div>
      <ul class="venue-grid reveal" style="--d:.12s">
        {
          platforms.map((p) => (
            <li class="venue-card">
              <span class="venue-name">{p.name}</span>
              <span class="venue-meta mono">{p.type === 'crowdfunding' ? 'Crowdfunding' : p.type === 'secondary' ? 'Secondaries' : p.type === 'pre-ipo' ? 'Pre-IPO' : 'SPVs'} · {p.region}</span>
            </li>
          ))
        }
      </ul>
      <p class="center small muted reveal" style="margin-top:1.5rem">
        Venue names indicate the markets Bundle is built to scan — not partnerships or endorsements.
      </p>
    </div>
  </section>

  <!-- ============ 5. HOW IT WORKS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">How it works</p>
        <h2 class="h2 reveal" style="--d:.05s">Discover. Compare. Execute.</h2>
      </div>
      <div class="grid cols-3">
        {
          steps.map((s, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="icon-chip"><Icon name={s.icon} /></span>
              <h3 class="h3 card-title">{s.title}</h3>
              <p class="small muted">{s.body}</p>
            </article>
          ))
        }
      </div>
      <p class="center reveal" style="margin-top:2rem">
        <a class="text-link" href="/how-it-works">The full journey, step by step <span class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ============ 6. THE EDGE ============ -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">Your edge</p>
        <h2 class="h2 reveal" style="--d:.05s">Built to make you faster than the market</h2>
      </div>
      <div class="grid cols-3">
        {
          edges.map((e, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="icon-chip"><Icon name={e.icon} /></span>
              <h3 class="h3 card-title">{e.title}</h3>
              <p class="small muted">{e.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ 7. QUIET DETAIL (info, tucked away) ============ -->
  <section class="section tight">
    <div class="container narrow">
      <div class="faq reveal">
        <details>
          <summary>How does Bundle make money?</summary>
          <div class="faq-body">
            <p>
              Bundle is free for investors. When venues operate referral or
              partner programmes, Bundle may earn a fee when you complete an
              investment we routed — never by marking up the price you pay.
              Where no programme exists, the deal is listed anyway: coverage
              comes first.
            </p>
          </div>
        </details>
        <details>
          <summary>Is Bundle regulated? Do you hold my money?</summary>
          <div class="faq-body">
            <p>
              Bundle never holds your money or your shares — you invest directly
              on the venue that lists the deal, under its own regulatory
              permissions. Bundle Technologies Ltd is a pre-launch technology
              company; any activities that require FCA authorisation will only
              be offered once the appropriate permissions or partnerships are in
              place.
            </p>
          </div>
        </details>
        <details>
          <summary>Are the prices on this page live?</summary>
          <div class="faq-body">
            <p>
              Not yet. Everything on this site is illustrative demo data while
              we build. Private-market pricing is indicative by nature — even at
              launch, quotes reflect the venue's latest listed price, not a
              continuous exchange feed.
            </p>
          </div>
        </details>
        <details>
          <summary>What are the risks?</summary>
          <div class="faq-body">
            <p>
              The same as investing on any of the underlying venues: startups
              and private companies fail often, shares are illiquid, dilution is
              normal and you may lose everything you invest. Aggregation makes
              the market easier to see — it does not make it safer. Read the
              <a href="/legal/risk-warning">full risk warning</a>.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ============ 8. FINAL CTA ============ -->
  <section class="section final-cta bg-grid">
    <div class="container">
      <div class="split">
        <div>
          <p class="eyebrow reveal">Early access</p>
          <h2 class="h2 reveal" style="--d:.05s">
            The whole private market.<br /><em class="serif-aside">On your screen first.</em>
          </h2>
          <p class="lead reveal" style="--d:.1s">
            We're opening the terminal to the waitlist in order of sign-up.
            Watchlists, alerts and the full screener from day one.
          </p>
        </div>
        <div class="card waitlist-card reveal" style="--d:.12s">
          <h3 class="h3">Get early access</h3>
          <p class="small muted">Be first on the terminal when the doors open.</p>
          <WaitlistForm compact />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(2.75rem, 5.5vw, 4.5rem) clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: clamp(2.25rem, 4.5vw, 4rem);
    align-items: center;
  }

  .hero-search {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.8rem;
    padding: 0.45rem 0.55rem 0.45rem 1rem;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-radius: 12px;
    max-width: 33rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .hero-search:focus-within {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(31, 210, 192, 0.14);
  }

  .hero-search svg {
    color: var(--faint);
    flex: none;
  }

  .hero-search input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: none;
    color: var(--ink);
    font: inherit;
    font-size: 0.98rem;
  }

  .hero-search input::placeholder {
    color: var(--faint);
  }

  .hero-search input:focus {
    outline: none;
  }

  .hero-stats {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.8rem;
    padding: 0;
    margin: 1.6rem 0 0;
    font-size: 0.82rem;
    color: var(--text-2);
  }

  .hero-stats strong {
    color: var(--teal);
    font-weight: 500;
    font-size: 1rem;
  }

  /* Market board */
  .board {
    overflow: hidden;
    box-shadow: var(--shadow-l), 0 0 80px -30px rgba(31, 210, 192, 0.25);
  }

  .board-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--line);
    background: #0b111c;
  }

  .board-live {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-2);
  }

  .board-tabs {
    display: flex;
    gap: 0.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 9px;
    padding: 0.2rem;
  }

  .board-tabs [role='tab'] {
    border: 0;
    background: none;
    color: var(--text-2);
    font-size: 0.8rem;
    font-weight: 550;
    padding: 0.32rem 0.7rem;
    border-radius: 7px;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .board-tabs [role='tab'][aria-selected='true'] {
    background: var(--tint);
    color: var(--ink);
  }

  .board-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .board-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1.35fr) minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.62rem 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--text);
    transition: background-color 0.13s ease;
  }

  .board-rows li:last-child .board-row {
    border-bottom: 0;
  }

  .board-row:hover {
    background: rgba(31, 210, 192, 0.045);
  }

  .br-avatar {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--h);
    background: color-mix(in srgb, var(--h) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--h) 28%, transparent);
  }

  .br-id {
    display: grid;
    min-width: 0;
  }

  .br-name {
    font-weight: 570;
    font-size: 0.9rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .br-src {
    font-size: 0.7rem;
    color: var(--faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .br-prog {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
  }

  .br-prog-label {
    font-size: 0.66rem;
    color: var(--text-2);
  }

  .br-val {
    font-size: 0.78rem;
    color: var(--text-2);
    text-align: left;
  }

  .br-price {
    font-size: 0.9rem;
    color: var(--ink);
    text-align: right;
  }

  .br-change {
    font-size: 0.78rem;
    min-width: 4.2rem;
    text-align: right;
  }

  .br-change.flat {
    color: var(--faint);
  }

  .board-foot {
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--line);
    background: #0b111c;
    font-size: 0.88rem;
  }

  .board-caption {
    margin-top: 0.7rem;
    font-size: 0.72rem;
    color: var(--faint);
    text-align: right;
  }

  @media (max-width: 1023px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .br-val, .br-prog {
      display: none;
    }

    .board-row {
      grid-template-columns: auto minmax(0, 1fr) auto auto;
    }
  }

  /* Rails */
  .rail-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.15rem;
  }

  .rail-head h2 {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
  }

  .rail-head h2 :global(svg) {
    color: var(--teal);
  }

  /* Venues */
  .venue-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.85rem;
  }

  .venue-card {
    padding: 1rem 1.1rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--line-2);
    border-radius: var(--r-m);
    display: grid;
    gap: 0.2rem;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .venue-card:hover {
    border-color: rgba(31, 210, 192, 0.4);
    background: rgba(31, 210, 192, 0.04);
  }

  .venue-name {
    font-family: var(--font-display);
    font-weight: 600;
    color: #fff;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
  }

  .venue-meta {
    font-size: 0.66rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-2);
  }

  @media (max-width: 1000px) {
    .venue-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 600px) {
    .venue-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Cards general */
  .card-title {
    margin-top: 1.1rem;
  }

  .card .small:last-child {
    margin-bottom: 0;
  }

  /* Final CTA */
  .final-cta {
    border-top: 1px solid var(--line);
  }

  .waitlist-card {
    padding: clamp(1.6rem, 3.5vw, 2.25rem);
  }

  .waitlist-card .h3 {
    margin-bottom: 0.3rem;
  }
</style>
