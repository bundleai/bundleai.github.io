---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CTABand from '../components/CTABand.astro';
import DealCard from '../components/DealCard.astro';
import { deals } from '../data/deals';

const secondaries = deals.filter((d) => d.type === 'secondary');

const venueRows = [
  { venue: 'Forge Global', region: 'US', model: 'Marketplace + data', access: 'Accredited investors', note: 'Deep late-stage inventory' },
  { venue: 'Hiive', region: 'US · CA', model: 'Order-book marketplace', access: 'Accredited investors', note: 'Transparent bid/ask on VC-backed names' },
  { venue: 'EquityZen', region: 'US', model: 'Funds over single names', access: 'Accredited investors', note: 'Lower minimums via pooled funds' },
  { venue: 'Nasdaq Private Market', region: 'US', model: 'Company-sponsored programmes', access: 'Varies by programme', note: 'Tenders and structured liquidity events' },
  { venue: 'PISCES venues (UK)', region: 'UK', model: 'Intermittent auction windows', access: 'Rules set per event', note: 'LSE PSM, JP Jenkins, Asset Match' },
];

const whys = [
  {
    icon: 'search',
    title: 'One tape, every venue',
    body: 'Blocks and tenders are scattered across marketplaces that don’t talk to each other. Bundle merges them into one tape you can actually watch.',
  },
  {
    icon: 'pulse',
    title: 'Price against the last round',
    body: 'A block is only cheap relative to something. Bundle shows every listing against the company’s last primary round, so premiums and discounts are visible at a glance.',
  },
  {
    icon: 'bell',
    title: 'Alerts on the names you track',
    body: 'Follow a company once, and get pinged whenever a block lists, a tender opens, or a UK PISCES window is announced for it — on any venue.',
  },
];
---

<BaseLayout
  title="Secondaries"
  description="Track secondary blocks and tenders in pre-IPO companies across Forge, Hiive, EquityZen, Nasdaq Private Market and UK PISCES venues — one tape, one watchlist."
>
  <PageHero
    eyebrow="Markets · Secondaries"
    title="The secondary tape, <em>finally in one place.</em>"
    lead="Employee blocks, fund tenders and structured liquidity windows trade every week across half a dozen marketplaces. Bundle puts them on one screen, priced against the last round."
  >
    <a slot="actions" href="/deals?type=secondary" class="btn btn-primary btn-lg">Watch the tape <span class="arrow">→</span></a>
    <a slot="actions" href="/waitlist" class="btn btn-ghost btn-lg">Get early access</a>
  </PageHero>

  <!-- Live rail -->
  <section class="section tight">
    <div class="container">
      <div class="rail-head reveal">
        <h2 class="h3"><Icon name="exchange" size={18} /> On the tape now</h2>
        <a href="/deals?type=secondary" class="text-link small">Full screener <span class="arrow">→</span></a>
      </div>
      <div class="grid cols-3">
        {secondaries.slice(0, 6).map((d, i) => <DealCard deal={d} class="reveal" style={`--d:${(i % 3) * 0.06}s`} />)}
      </div>
      <p class="small muted" style="margin-top:0.9rem">
        Indicative marks from venue public pages, as of 19 July 2026 — not live quotes or offers.
      </p>
    </div>
  </section>

  <!-- Why -->
  <section class="section section-tint-full">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The edge</p>
        <h2 class="h2 reveal" style="--d:.05s">Secondaries reward whoever sees the market first</h2>
      </div>
      <div class="grid cols-3">
        {
          whys.map((w, i) => (
            <article class="card card-hover reveal" style={`--d:${i * 0.07}s`}>
              <span class="icon-chip"><Icon name={w.icon} /></span>
              <h3 class="h3" style="margin-top:1.1rem">{w.title}</h3>
              <p class="small muted" style="margin-bottom:0">{w.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Venue map -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow reveal">The venues</p>
        <h2 class="h2 reveal" style="--d:.05s">Where secondary deals actually live</h2>
        <p class="lead reveal" style="--d:.1s">
          Each venue has its own model, minimums and eligibility rules. Bundle
          shows you what applies before you click through.
        </p>
      </div>
      <div class="table-wrap reveal">
        <table class="table">
          <thead>
            <tr>
              <th>Venue</th>
              <th>Region</th>
              <th>Model</th>
              <th>Who can buy</th>
              <th>Known for</th>
            </tr>
          </thead>
          <tbody>
            {
              venueRows.map((r) => (
                <tr>
                  <td><strong style="color:var(--ink)">{r.venue}</strong></td>
                  <td class="num">{r.region}</td>
                  <td>{r.model}</td>
                  <td>{r.access}</td>
                  <td>{r.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="small muted reveal" style="margin-top:1rem">
        Indicative summaries, not offers or endorsements — always check the
        venue's current terms. Eligibility, fees and minimums change.
      </p>
    </div>
  </section>

  <!-- PISCES note (kept, condensed) -->
  <section class="section section-ink grain">
    <div class="container narrow">
      <p class="eyebrow reveal">The UK angle</p>
      <h2 class="h2 reveal" style="--d:.05s">PISCES turned UK private liquidity into a real market</h2>
      <p class="reveal" style="--d:.1s">
        Since 2026, the UK's PISCES framework lets approved venues run
        regulated, intermittent trading windows in private-company shares —
        scheduled auctions with refreshed disclosure, rather than a continuous
        ticker. As companies opt in, those windows appear on Bundle's tape next
        to everything else, with the venue's own eligibility rules attached.
      </p>
      <p class="small muted reveal" style="--d:.14s">
        One honest caveat: secondary markets create <em>possible</em> liquidity,
        not guaranteed liquidity. Private shares can remain unsellable for
        years. <a href="/legal/risk-warning">The risk warning applies in full.</a>
      </p>
    </div>
  </section>

  <CTABand
    title="Never miss <em>a block again.</em>"
    sub="Watchlists and listing alerts across every secondary venue, from day one of early access."
    primaryLabel="Get early access"
    primaryHref="/waitlist"
    secondaryLabel="Browse the tape"
    secondaryHref="/deals?type=secondary"
  />
</BaseLayout>

<style>
  .rail-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.15rem;
  }

  .rail-head h2 {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
  }

  .rail-head h2 :global(svg) {
    color: var(--teal);
  }
</style>
